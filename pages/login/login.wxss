/* pages/login/login.wxss - ColorUI 年轻活泼风格 */

.login-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 180rpx 40rpx 60rpx;
  box-sizing: border-box;
  margin-top: -16rpx; /* 重叠 cu-custom 底部，与导航栏渐变连贯 */
}

.bg-gradual-blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
  background-color: rgba(255, 255, 255, 0.95);
  transition: transform 0.3s ease;
}


.app-name {
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.app-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.opacity-80 {
  opacity: 0.9;
}

/* 登录/注册切换 */
.tab-bar {
  position: relative;
  width: 100%;
  max-width: 520rpx;
  margin-bottom: 50rpx;
  padding: 8rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50rpx;
}

.tab-slider {
  position: absolute;
  left: 8rpx;
  top: 8rpx;
  width: calc(50% - 8rpx);
  height: calc(100% - 16rpx);
  background: #fff;
  border-radius: 44rpx;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-slider-right {
  transform: translateX(100%);
}

.tab-bar .tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  border-radius: 44rpx;
  position: relative;
  z-index: 1;
  transition: color 0.3s ease;
}

.tab-bar .tab-item.active {
  color: #667eea;
  font-weight: bold;
}


/* 表单区域 */
.form-section {
  width: 100%;
  max-width: 600rpx;
}

.form-section .cu-form-group {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}


.margin-top { margin-top: 0; }
.margin-top-lg { margin-top: 40rpx; }
.margin-bottom { margin-bottom: 30rpx; }

/* 注册头像 */
.avatar-section {
  display: flex;
  justify-content: center;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
  transition: transform 0.25s ease;
}


.avatar-tip {
  font-size: 24rpx;
}
