<!--pages/login/login.wxml - ColorUI 风格 -->
<cu-custom bgColor="bg-gradual-blue"></cu-custom>
<view class="login-container bg-gradual-blue">
  <view class="logo-section animation-scale-up">
    <image class="logo round shadow" src="/images/logo.png" mode="aspectFit"></image>
    <text class="app-name text-white">Who Pay</text>
    <text class="app-desc text-white opacity-80">谁付的钱？？？</text>
  </view>

  <!-- 登录/注册切换 -->
  <view class="tab-bar flex animation-fade">
    <view class="tab-slider {{currentTab === 'register' ? 'tab-slider-right' : ''}}"></view>
    <view 
      class="tab-item {{currentTab === 'login' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="login"
    >登录</view>
    <view 
      class="tab-item {{currentTab === 'register' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="register"
    >注册</view>
  </view>

  <!-- 登录表单 -->
  <view class="form-section {{currentTab === 'login' ? 'animation-slide-bottom' : ''}}" wx:if="{{currentTab === 'login'}}">
    <view class="cu-form-group margin-top">
      <view class="title"><text class="cuIcon-people text-grey"></text></view>
      <input 
        placeholder="请输入账号" 
        value="{{loginForm.account}}"
        bindinput="onLoginAccountInput"
        placeholder-class="text-gray"
      />
    </view>
    <view class="cu-form-group">
      <view class="title"><text class="cuIcon-lock text-grey"></text></view>
      <input 
        type="password"
        placeholder="请输入密码" 
        value="{{loginForm.password}}"
        bindinput="onLoginPasswordInput"
        placeholder-class="text-gray"
      />
    </view>
    <button class="cu-btn block bg-white text-blue shadow lg round margin-top-lg" bindtap="onLogin" >登录</button>
  </view>

  <!-- 注册表单 -->
  <view class="form-section {{currentTab === 'register' ? 'animation-slide-bottom' : ''}}" wx:if="{{currentTab === 'register'}}">
    <view class="avatar-section margin-bottom">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image 
          class="avatar-preview round"
          src="{{registerForm.avatarUrl || '/images/default-avatar.png'}}" 
          mode="aspectFill"
        ></image>
        <text class="avatar-tip text-white opacity-80">点击选择头像</text>
      </button>
    </view>
    <view class="cu-form-group">
      <view class="title"><text class="cuIcon-people text-grey"></text></view>
      <input 
        placeholder="请输入账号" 
        value="{{registerForm.account}}"
        bindinput="onRegisterAccountInput"
        placeholder-class="text-gray"
      />
    </view>
    <view class="cu-form-group">
      <view class="title"><text class="cuIcon-lock text-grey"></text></view>
      <input 
        type="password"
        placeholder="请输入密码" 
        value="{{registerForm.password}}"
        bindinput="onRegisterPasswordInput"
        placeholder-class="text-gray"
      />
    </view>
    <button class="cu-btn block bg-white text-blue shadow lg round margin-top-lg" bindtap="onRegister" >注册</button>
  </view>
</view>
