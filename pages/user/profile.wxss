/* pages/user/profile.wxss - ColorUI 年轻活泼 */
.profile-page {
  min-height: 100vh;
  /* 顶部与 cu-custom 同款 135deg 渐变，下层灰底从 360rpx 开始 */
  background: linear-gradient(to bottom, transparent 0, transparent 360rpx, #f7f8fa 360rpx, #f7f8fa 100%),
    linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.user-card {
  background: transparent;
  padding: 48rpx 40rpx;
  margin-top: -16rpx;
}

.user-header {
  display: flex;
  align-items: center;
}

.user-header:active {
  opacity: 0.95;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  transition: transform 0.2s ease;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.edit-icon {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
}

.menu-list {
  background-color: #fff;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.08);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  border-bottom: 1rpx solid rgb(236, 221, 255);
  transition: background 0.2s ease;
}

.menu-item:active {
  background: #f8f9fe;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 28rpx;
  color:#715EBC;
  font-weight: 600;
}

.menu-arrow {
  display: flex;
  align-items: center;
}
.menu-icon {
  width: 40rpx;
  height: 40rpx;
}

.menu-arrow image {
  width: 36rpx;
  height: 36rpx;
}

.logout-section {
  padding: 40rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #fff;
  color: #fa5151;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: 2rpx solid #fa5151;
  padding: 0rpx;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 80%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.modal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 30rpx;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.modal-footer button {
  flex: 1;
}

.avatar-options {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.default-avatars .avatar-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
}

.avatar-grid .avatar-item {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #eee;
}

.avatar-grid .avatar-item:active {
  opacity: 0.9;
}

.option-btn {
  height: 70rpx;
  line-height: 70rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 26rpx;
  border: none;
  transition: transform 0.2s ease;
  padding: 0
}

/* ========== 消息通知 ========== */
.notification-badge {
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  min-width: 32rpx;
  text-align: center;
}

.notification-modal {
  max-height: 70vh;
}

.notification-list {
  max-height: 60vh;
  overflow-y: auto;
}

.application-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.application-item:last-child {
  border-bottom: none;
}

.application-user {
  display: flex;
  align-items: center;
  flex: 1;
}

.app-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.app-detail {
  display: flex;
  flex-direction: column;
}

.app-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.app-target {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 2rpx;
}

.app-type {
  font-size: 22rpx;
  color: #999;
}

.application-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.btn-approve {
  background-color: #10b981 !important;
  color: #fff !important;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  border: none;
}

.btn-reject {
  background-color: #ef4444 !important;
  color: #fff !important;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  border: none;
}

.empty-notifications {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}
