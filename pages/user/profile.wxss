/* pages/user/profile.wxss - ColorUI 年轻活泼 */

page {
  background: #f7f8fa;
}

/* 整页灰底（与 app.json window.backgroundColor 一致），紫区只占顶部一块 */
.page-profile {
  min-height: 100vh;
  background: #f7f8fa;
  box-sizing: border-box;
}

.profile-hero {
  position: relative;
  overflow: hidden;
  background: var(--gradualBlue);
  box-sizing: border-box;
}

.profile-hero--custom {
  background: transparent;
}

.profile-hero__bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.profile-hero__shade {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
  background: linear-gradient(
    135deg,
    rgba(102, 126, 234, 0.78) 0%,
    rgba(118, 75, 162, 0.74) 100%
  );
}

.profile-hero__inner {
  position: relative;
  z-index: 2;
}

.profile-body {
  background: #f7f8fa;
  padding-top: 8rpx;
  box-sizing: border-box;
}

/* scroll-view 下拉刷新容器 */
.refresh-scroll {
  overflow: hidden;
}

.user-card {
  background: transparent;
  padding: 48rpx 40rpx;
  margin-top: 46rpx;
}

.user-header {
  display: flex;
  align-items: flex-start;
}

.user-header:active {
  opacity: 0.95;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  margin-top: 4rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  transition: transform 0.2s ease;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-bio {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.45;
  max-height: 76rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  word-break: break-all;
}

.user-bio-placeholder {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
}

.edit-icon {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
}

.menu-list {
  background-color: #fff;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.08);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  border-bottom: 1rpx solid rgb(236, 221, 255);
  transition: background 0.2s ease;
}

.menu-item:active {
  background: #f8f9fe;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 28rpx;
  color:#715EBC;
  font-weight: 600;
}

.menu-badge {
  margin-right: 18rpx;
  box-sizing: border-box;
  width: 38rpx;
  height: 38rpx;
  padding: 0;
  border-radius: 50%;
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 38rpx;
  text-align: center;
  white-space: nowrap;
  box-shadow: rgba(0, 0, 0, 0.16) 0px 1px 4px;
}

.menu-arrow {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-direction: row;
}
.menu-icon {
  width: 40rpx;
  height: 40rpx;
}

.menu-arrow image {
  width: 28rpx;
  height: 28rpx;
}

.logout-section {
  padding: 40rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #fff;
  color: #fa5151;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: 2rpx solid #fa5151;
  padding: 0rpx;
}

.avatar-options {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.default-avatars .avatar-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
}

.avatar-grid .avatar-item {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #eee;
}

.avatar-grid .avatar-item:active {
  opacity: 0.9;
}

.option-btn {
  height: 70rpx;
  line-height: 70rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 26rpx;
  border: none;
  transition: transform 0.2s ease;
  padding: 0
}

/* ========== 消息通知 ========== */
.notification-badge {
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  min-width: 32rpx;
  text-align: center;
}

.notification-modal {
  max-height: 70vh;
}

.notification-list {
  max-height: 60vh;
  overflow-y: auto;
}

.application-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.application-item:last-child {
  border-bottom: none;
}

.application-user {
  display: flex;
  align-items: center;
  flex: 1;
}

.app-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.app-detail {
  display: flex;
  flex-direction: column;
}

.app-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.app-target {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 2rpx;
}

.app-type {
  font-size: 22rpx;
  color: #999;
}

.application-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.btn-approve {
  background-color: #10b981 !important;
  color: #fff !important;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  border: none;
}

.btn-reject {
  background-color: #ef4444 !important;
  color: #fff !important;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  border: none;
}

.empty-notifications {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 联系我们按钮：重置原生 button 样式，继承 menu-item 布局 */
.menu-contact-btn {
  background-color: transparent;
  border: none;
  border-radius: 0;
  padding: 40rpx !important;
  margin: 0 !important;
  line-height: normal;
  font-size: inherit;
  color: inherit;
  text-align: left;
  /* 继承 menu-item 的 padding，覆盖 button 默认 padding */
  padding: 40rpx !important;
  /* 确保 menu-item 布局生效 */
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100% !important;
  box-sizing: border-box;
}

.menu-contact-btn::after {
  border: none;
}
