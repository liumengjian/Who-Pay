<!--pages/user/profile.wxml-->
<view class="page-profile">
  <!-- 仅导航+头像区铺一条渐变，避免与下方区域叠两层紫色 -->
  <view class="profile-hero {{profileBgUrl ? 'profile-hero--custom' : ''}}">
    <image wx:if="{{profileBgUrl}}" class="profile-hero__bg" src="{{profileBgUrl}}" mode="aspectFill" />
    <!-- <view wx:if="{{profileBgUrl}}" class="profile-hero__shade"></view> -->
    <view class="profile-hero__inner">
    <cu-custom bgColor="bg-hero-transparent">
    </cu-custom>
    <view class="user-card">
      <view class="user-header">
        <image
          class="avatar"
          src="{{userInfo.avatarUrl || userInfo.avatar || '/images/default-avatar.png'}}"
          mode="aspectFill"
          bindtap="goMyHome"
        ></image>
        <view class="user-info">
          <text class="nickname" bindtap="goMyHome">{{userInfo.nickName || '未设置'}}</text>
          <text wx:if="{{userInfo.bio}}" class="user-bio" bindtap="goMyHome">{{userInfo.bio}}</text>
          <text wx:else class="user-bio user-bio-placeholder" bindtap="goMyHome">暂无签名，点此进入主页编辑</text>
        </view>
      </view>
    </view>
    </view>
  </view>

  <view class="profile-body">
  <!-- 功能列表 -->
  <view class="menu-list">
    <view class="menu-item" wx:if="{{isAdminUser}}" bindtap="goToPublishNotice">
      <view class="menu-left">
        <image class="menu-icon" src="/images/tixing.png" mode="aspectFit" />
        <text class="menu-text">发布通知</text>
      </view>
      <view class="menu-arrow">
        <image src="/images/pointer-right.png" mode="aspectFit" />
      </view>
    </view>
    <view class="menu-item" bindtap="goToFriends" wx:if="{{enableSocial}}">
      <view class="menu-left">
        <image class="menu-icon" src="/images/friend.png" mode="aspectFit" />
        <text class="menu-text">好友</text>
      </view>
      <view class="menu-arrow">
        <image src="/images/pointer-right.png" mode="aspectFit" />
      </view>
    </view>
    <view class="menu-item" bindtap="goToChats" wx:if="{{enableSocial}}">
      <view class="menu-left">
        <image class="menu-icon" src="/images/chat.png" mode="aspectFit" />
        <text class="menu-text">聊天</text>
      </view>
      <view class="menu-arrow">
        <text class="menu-badge" wx:if="{{unreadChatCount > 0 || unreadChatCount === '99+'}}">{{unreadChatCount}}</text>
        <image src="/images/pointer-right.png" mode="aspectFit" />
      </view>
    </view>
     <view class="menu-item" bindtap="goToNotifications">
      <view class="menu-left">
        <image class="menu-icon" src="/images/tixing.png" mode="aspectFit" />
        <text class="menu-text">消息通知</text>
      </view>
      <view class="menu-arrow">
        <text class="menu-badge" wx:if="{{notificationBadgeCount > 0}}">{{notificationBadgeText}}</text>
        <image src="/images/pointer-right.png" mode="aspectFit" />
      </view>
    </view>
    
    <view class="menu-item" bindtap="goToHistory">
      <view class="menu-left">
        <image class="menu-icon" src="/images/lishi.png" mode="aspectFit" />
        <text class="menu-text">历史活动</text>
      </view>
      <view class="menu-arrow">
        <image src="/images/pointer-right.png" mode="aspectFit" />
      </view>
    </view>
    <view class="menu-item" bindtap="goToPaymentManage">
      <view class="menu-left">
        <image class="menu-icon" src="/images/zhifu.png" mode="aspectFit" />
        <text class="menu-text">支付记录</text>
      </view>
      <view class="menu-arrow">
        <image src="/images/pointer-right.png" mode="aspectFit" />
      </view>
    </view>
    <button class="menu-item menu-contact-btn" open-type="contact">
      <view class="menu-left">
        <image class="menu-icon" src="/images/kefu.png" mode="aspectFit" />
        <text class="menu-text">联系我们</text>
      </view>
      <view class="menu-arrow">
        <image src="/images/pointer-right.png" mode="aspectFit" />
      </view>
    </button>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>
  </view>
</view>