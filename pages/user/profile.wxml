<!--pages/user/profile.wxml-->
<cu-custom bgColor="bg-gradual-blue">
  <view slot="content" class="text-white">我的</view>
</cu-custom>
<view class="profile-page">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-header">
      <image 
        class="avatar" 
        src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" 
        mode="aspectFill"
        bindtap="editAvatar"
      ></image>
      <view class="user-info">
        <text class="nickname" bindtap="editNickname">{{userInfo.nickName || '未设置'}}</text>
        <text class="phone">{{userInfo.phone || ''}}</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToHistory">
      <view class="menu-left">
        <image class="menu-icon" src="/images/lishi.png" mode="aspectFit" />
        <text class="menu-text">历史活动</text>
      </view>
      <view class="menu-arrow">
        <image src="/images/pointer-right.png" mode="aspectFit" />
      </view>
    </view>
    <view class="menu-item" bindtap="goToPaymentManage">
      <view class="menu-left">
        <image class="menu-icon" src="/images/zhifu.png" mode="aspectFit" />
        <text class="menu-text">我的支付记录</text>
      </view>
      <view class="menu-arrow">
        <image src="/images/pointer-right.png" mode="aspectFit" />
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>

  <!-- 编辑昵称弹窗 -->
  <view class="modal {{showEditNickname ? 'show' : ''}}" catchtap="hideEditNickname">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">修改昵称</text>
        <text class="modal-close" bindtap="hideEditNickname">×</text>
      </view>
      <view class="modal-body">
        <input 
          class="input" 
          type="text" 
          placeholder="请输入昵称"
          value="{{editNickname}}"
          bindinput="onNicknameInput"
          maxlength="20"
        />
      </view>
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="hideEditNickname">取消</button>
        <button class="btn-primary" bindtap="handleUpdateNickname">确定</button>
      </view>
    </view>
  </view>

  <!-- 编辑头像弹窗 -->
  <view class="modal {{showEditAvatar ? 'show' : ''}}" catchtap="hideEditAvatar">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">修改头像</text>
        <text class="modal-close" bindtap="hideEditAvatar">×</text>
      </view>
      <view class="modal-body">
        <view class="avatar-options">
          <button class="option-btn" bindtap="chooseFromAlbum">从相册选择</button>
          <view class="default-avatars">
            <text class="avatar-label">默认头像</text>
            <view class="avatar-grid">
              <image
                wx:for="{{defaultAvatars}}"
                wx:key="*this"
                class="avatar-item"
                src="{{item}}"
                mode="aspectFill"
                bindtap="selectDefaultAvatar"
                data-url="{{item}}"
              />
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
