<!--pages/payment/manage.wxml-->
<view class="manage-page">
  <view class="payment-list">
    <view wx:if="{{payments.length > 0}}">
      <view 
        class="payment-card" 
        wx:for="{{payments}}" 
        wx:key="_id"
      >
        <view class="payment-header">
          <text class="payment-amount">¥{{item.amount}}</text>
          <view class="payment-actions">
            <text class="action-btn edit-btn" bindtap="editPayment" data-index="{{index}}">编辑</text>
            <text class="action-btn delete-btn" bindtap="deletePayment" data-id="{{item._id}}">删除</text>
          </view>
        </view>
        <view class="payment-body">
          <text wx:if="{{item.remark}}" class="payment-remark">{{item.remark}}</text>
          <text wx:else class="payment-remark text-muted">无备注</text>
          <text class="payment-time">{{item.createTime}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:else class="empty-state">
      <text class="empty-icon">💰</text>
      <text class="empty-text">暂无支付记录</text>
    </view>
  </view>

  <!-- 底部添加按钮 -->
  <view class="action-bar">
    <button class="add-btn" bindtap="showAddModal">+ 添加记录</button>
  </view>

  <!-- 添加/编辑支付记录弹窗 -->
  <view class="modal {{showModal ? 'show' : ''}}" catchtap="hideModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{isEdit ? '编辑支付记录' : '添加支付记录'}}</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">金额 <text class="required">*</text></text>
          <input 
            class="input" 
            type="digit" 
            placeholder="请输入金额"
            value="{{formAmount}}"
            bindinput="onAmountInput"
          />
        </view>
        <view class="input-group">
          <text class="input-label">备注</text>
          <input 
            class="input" 
            type="text" 
            placeholder="选填"
            value="{{formRemark}}"
            bindinput="onRemarkInput"
            maxlength="50"
          />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="hideModal">取消</button>
        <button class="btn-primary" bindtap="handleSubmit">确定</button>
      </view>
    </view>
  </view>
</view>
