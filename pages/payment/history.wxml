<cu-custom bgColor="bg-gradual-blue" isBack="{{true}}">
  <view slot="content" class="text-white">历史支付</view>
</cu-custom>
<view class="history-page padding">
  <view class="filter-bar bg-white round margin-bottom-sm" wx:if="{{rawPayments.length > 0}}">
    <picker
      mode="selector"
      range="{{activityOptions}}"
      range-key="name"
      value="{{filterIndex}}"
      bindchange="onFilterActivityChange"
    >
      <view class="filter-picker-inner flex-between">
        <text class="text-bold text-black">{{activityOptions[filterIndex].name}}</text>
        <text class="text-gray text-sm">切换</text>
      </view>
    </picker>
  </view>
  <view wx:if="{{payments.length > 0}}">
    <view class="pay-card margin-bottom" wx:for="{{payments}}" wx:key="id">
      <view class="flex-between">
        <text class="text-bold">{{item.activityName || '活动'}}</text>
        <text class="text-price">¥{{item.amount}}</text>
      </view>
      <text wx:if="{{item.remark}}" class="text-sm block margin-top-xs">{{item.remark}}</text>
      <text class="text-gray text-sm block margin-top-xs">{{item.createTime}}</text>
    </view>
  </view>
  <view wx:else class="empty text-gray text-center padding-xl">
    <empty-state tip="暂无支付记录" />
  </view>
</view>
