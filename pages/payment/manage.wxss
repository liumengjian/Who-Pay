/* pages/payment/manage.wxss - ColorUI 年轻活泼 */

/* scroll-view 下拉刷新容器 */
.refresh-scroll {
  overflow: hidden;
}

.manage-page {
  padding-bottom: 120rpx;
  background: linear-gradient(to bottom,
    #667eea 0,
    #764ba2 120rpx,
    #f7f8fa 360rpx
  );
}

.payment-list {
  padding: 24rpx;
}

.payment-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
  transition: transform 0.2s ease;
}


.payment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.payment-amount {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
}

.payment-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 28rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.edit-btn {
  color: #667eea;
  background-color: rgba(102, 126, 234, 0.12);
  transition: transform 0.2s ease;
}

.edit-btn:active,
.delete-btn:active {
  opacity: 0.8;
}

.delete-btn {
  color: #fa5151;
  background-color: rgba(250, 81, 81, 0.1);
}

.payment-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.payment-remark {
  font-size: 28rpx;
  color: #333;
}

.payment-time {
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.add-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}
