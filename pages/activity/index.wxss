/* pages/activity/index.wxss - ColorUI 年轻活泼 */
.activity-page {
  min-height: 100vh;
  padding-bottom: 180rpx;
  background: #f7f8fa;
}

.bg-gradual-blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header-section {
  padding: 36rpx 32rpx 48rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-info:active {
  opacity: 0.9;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  margin-left: 24rpx;
  letter-spacing: 1rpx;
}

.activity-list {
  margin-top: -24rpx;
}

.cu-card-hover:active {
  transform: scale(0.98);
  transition: transform 0.2s ease;
}

.margin-bottom { margin-bottom: 24rpx; }
.margin-bottom-sm { margin-bottom: 16rpx; }
.margin-top-xs { margin-top: 8rpx; }
.margin-top-sm { margin-top: 16rpx; }
.margin-right-sm { margin-right: 16rpx; }
.margin-left { margin-left: 16rpx; }
.text-lg { font-size: 36rpx; }
.text-bold { font-weight: bold; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  box-shadow: 0 -4rpx 24rpx rgba(102, 126, 234, 0.15);
  z-index: 100;
}

/* 弹窗圆角与动画 */
.activity-page .cu-dialog {
  width: 85%;
  max-width: 600rpx;
  border-radius: 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(102, 126, 234, 0.2);
}

