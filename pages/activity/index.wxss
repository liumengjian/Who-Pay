/* pages/activity/index.wxss - ColorUI 年轻活泼 */

/* 大厅 / 创建弹窗打开时占位（与 cu-modal 叠放）；pointer-events 不拦截，由弹窗自身处理 */
.page-blocker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 998;
  pointer-events: none;
}

/* scroll-view 下拉刷新容器 — 高度由父级 flex 撑满 */
.refresh-scroll {
  overflow: hidden;
}

.activity-index-frame {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.activity-index-scroll {
  flex: 1;
  height: 0;
  min-height: 0;
}

.main-tab-swiper {
  flex: 1;
  height: 0;
  min-height: 0;
  width: 100%;
}

.main-tab-swiper-item {
  height: 100%;
  box-sizing: border-box;
}

.main-tab-scroll {
  height: 100%;
}

.activity-page {
  background: transparent;
  padding-bottom: 120rpx;
}

.bg-gradual-blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header-section {
  padding: 48rpx 40rpx;
  margin-top: -16rpx; /* 重叠 cu-custom 底部，与导航栏渐变连贯 */
  margin-bottom: 0;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-info:active {
  opacity: 0.9;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  margin-left: 24rpx;
  letter-spacing: 1rpx;
}

.activity-list {
  margin-top: 0;
  padding: 30rpx 42rpx;
}


.margin-bottom { margin-bottom: 24rpx; }
.margin-bottom-sm { margin-bottom: 16rpx; }
.margin-top-xs { margin-top: 8rpx; }
.margin-top-sm { margin-top: 16rpx; }
.margin-right-sm { margin-right: 16rpx; }
.margin-left { margin-left: 16rpx; }
.text-lg { font-size: 32rpx; }
.text-bold { font-weight: bold; }

.empty-wrapper {
  width: 100%;
  padding: 120rpx 40rpx;
  box-sizing: border-box;
}

.action-bar {
  position: fixed;
  bottom: -1px;
  left: 0;
  right: 0;
  box-shadow: 0 -4rpx 24rpx rgba(102, 126, 234, 0.15);
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 40rpx;
  min-height: 96rpx;
  padding: 14rpx 28rpx calc(14rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  /* 与 wx.hideTabBar/showTabBar 默认动画约 300ms 对齐，缓和 tab 显隐时底部位移 */
  transition: transform 300ms cubic-bezier(0.33, 1, 0.68, 1),
    padding-bottom 300ms cubic-bezier(0.33, 1, 0.68, 1);
}

.action-bar.flex.padding {
  padding: 14rpx 28rpx calc(14rpx + env(safe-area-inset-bottom));
}

.action-bar-single {
  flex: 1;
  margin-right: 0;
  max-width: 100%;
  height: 70rpx !important;
  line-height: 64rpx !important;
  padding: 0 !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  border-radius: 32rpx !important;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
}
.action-bar-active {
  padding: 36rpx !important;
}

/* 弹窗打开：禁用点击；略向下平移，贴近 tab 收起后的位置，与原生 tab 动画同步 */
.action-bar--under-modal {
  pointer-events: none;
  transform: translateY(calc(96rpx + env(safe-area-inset-bottom)));
}

/* 与活动详情页「+ / 添加支付」主按钮一致的紫蓝渐变 */
.activity-create-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  color: #fff !important;
  border: none !important;
  box-shadow:
    0 8rpx 20rpx rgba(102, 126, 234, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.22);
}

.activity-create-btn::after {
  border: none;
}

.hall-search .search-form {
  display: flex;
  align-items: center;
  width: 100%;
  border-radius: 999rpx;
  padding: 0 16rpx;
  min-height: 60rpx;
  margin: 0;
}

.hall-search .search-form input {
  flex: 1;
  font-size: 28rpx;
}

/* 弹窗圆角与宽度（立体样式见 app.wxss .cu-dialog） */
.activity-page .cu-dialog {
  width: 85%;
  max-width: 600rpx;
}

.sub-tabs {
  flex-shrink: 0;
  z-index: 10;
}

.hall-dialog {
  max-height: 85vh;
}

/* 加入活动 + 申请加入：底部并排一行 */
.hall-dual-actions {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: stretch;
  gap: 16rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
}

.hall-dual-actions .cu-btn {
  flex: 1;
  min-width: 0;
  margin: 0 !important;
  width: auto !important;
  height: 76rpx !important;
  min-height: 76rpx !important;
  line-height: 76rpx !important;
  padding: 0 16rpx !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  border-radius: 22rpx !important;
  box-sizing: border-box !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* 大厅活动详情：内容区按钮与全局弹窗统一（紧凑一行、立体） */
.hall-dialog .cu-btn {
  margin-left: 0 !important;
  margin-right: 0 !important;
}

.hall-dialog .cu-btn::after {
  border: none !important;
}

.hall-dialog .cu-btn.sm,
.hall-dialog .cu-btn.block {
  height: 76rpx !important;
  min-height: 76rpx !important;
  line-height: 76rpx !important;
  padding: 0 24rpx !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  border-radius: 22rpx !important;
  box-sizing: border-box !important;
}

.hall-dialog .cu-btn.block {
  width: 100% !important;
}

.hall-dialog .cu-btn.sm {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.hall-dialog .cu-btn.bg-blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  color: #fff !important;
  box-shadow:
    0 8rpx 20rpx rgba(102, 126, 234, 0.34),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.25) !important;
}

.hall-dialog .cu-btn.bg-green.light {
  background: #fff !important;
  color: #059669 !important;
  border: 1rpx solid rgba(5, 150, 105, 0.35) !important;
  box-shadow:
    0 4rpx 12rpx rgba(31, 41, 55, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 1) !important;
}

.hall-dialog .cu-btn.bg-grey {
  background: #f2f3f5 !important;
  color: #8e8e93 !important;
  border: 1rpx solid rgba(0, 0, 0, 0.06) !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9) !important;
}

.hall-scroll {
  max-height: 60vh;
}

.hall-member {
  width: 120rpx;
}

.mine-tab-list {
  padding: 0 28rpx 32rpx;
  margin-top: 24rpx;
}

/* 我的活动：简约立体卡片 */
.mine-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx 24rpx 24rpx;
  margin-bottom: 28rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  box-shadow:
    0 2rpx 6rpx rgba(31, 41, 55, 0.06),
    0 12rpx 36rpx rgba(102, 126, 234, 0.14),
    inset 0 1rpx 0 rgba(255, 255, 255, 1);
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.mine-card:active {
  opacity: 0.96;
  transform: scale(0.992);
}

.mine-card-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.mine-card-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.2);
}

.mine-card-body {
  flex: 1;
  min-width: 0;
}

.mine-card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1c1c1e;
  line-height: 1.35;
}

.mine-card-slogan {
  display: block;
  font-size: 24rpx;
  color: #8e8e93;
  margin-top: 8rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mine-card-arrow {
  flex-shrink: 0;
  font-size: 40rpx;
  color: #c7c7cc;
  font-weight: 300;
  line-height: 1;
}

.mine-card-teams {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #f2f2f7;
}

.mine-card-team + .mine-card-team {
  margin-top: 20rpx;
}

.mine-card-team-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #636366;
  margin-bottom: 14rpx;
}

.mine-card-members {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
}

.mine-card-member-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  margin-left: -14rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.mine-card-member-avatar:first-child {
  margin-left: 0;
}

.mine-card-empty {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f2f2f7;
  font-size: 24rpx;
  color: #aeaeb2;
  text-align: center;
}

.align-start {
  align-items: flex-start;
}

.create-avatar-row {
  display: flex;
  justify-content: center;
}

.avatar-pick-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  line-height: 1.4;
  border: none;
}

.avatar-pick-btn::after {
  border: none;
}

.create-act-avatar {
  width: 140rpx;
  height: 140rpx;
  display: block;
  margin: 0 auto;
}

/* ========== 首页悬浮笔记入口 + 弹层 ========== */
.float-notes-fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(196rpx + env(safe-area-inset-bottom));
  z-index: 150;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow:
    0 12rpx 36rpx rgba(102, 126, 234, 0.28),
    0 2rpx 8rpx rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.float-notes-fab--hover {
  opacity: 0.9;
  transform: scale(0.96);
}

.float-notes-fab__img {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
}

/* page-container 只包一层弹窗壳：居中 90% 高，内容从右下角方向缩放入场（呼应悬浮按钮） */
.float-notes-modal {
  position: relative;
  width: 100%;
  height: 100%;
  min-height: 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  /* 上内边距固定；底部只留安全区，关闭钮走文档流由 flex 占位，避免被 sheet 挡住 */
  padding: 90rpx 8rpx 0;
  padding-bottom: env(safe-area-inset-bottom);
  background: transparent;
  transform-origin: 92% 94%;
  animation: float-notes-from-fab 0.36s cubic-bezier(0.22, 1, 0.36, 1) both;
}

@keyframes float-notes-from-fab {
  from {
    opacity: 0;
    transform: scale(0.52);
  }

  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* 白卡片下方居中，距卡片 16px；参与 flex 占位，不用 absolute，避免被 sheet 盖住 */
.float-notes-modal__close {
  flex-shrink: 0;
  align-self: center;
  margin-top: 16px;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 40rpx;
  font-weight: 300;
  line-height: 1;
  color: #ffffff;
  position: relative;
  z-index: 2;
}

.float-notes-modal__close--hover {
  opacity: 0.82;
}

.float-notes-sheet {
  position: relative;
  flex: 1;
  min-height: 0;
  width: 100%;
  margin-top: 0;
  background: #fff;
  border-radius: 24rpx;
  box-shadow:
    0 24rpx 72rpx rgba(15, 23, 42, 0.18),
    0 0 0 1rpx rgba(15, 23, 42, 0.04);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
  z-index: 1;
}

.float-notes-sheet__head {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
}

.float-notes-sheet__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.5rpx;
}

.float-notes-loading {
  flex-shrink: 0;
  padding: 16rpx 32rpx 8rpx;
}

.float-notes-scroll {
  flex: 1;
  height: 0;
  min-height: 0;
  padding: 12rpx 20rpx 28rpx;
  box-sizing: border-box;
}

.float-notes-scroll__foot {
  height: 24rpx;
}

.float-notes-empty {
  padding: 80rpx 32rpx;
  text-align: center;
}

.float-notes-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow:
    0 4rpx 20rpx rgba(102, 126, 234, 0.07),
    0 0 0 1rpx rgba(15, 23, 42, 0.05);
  transition: box-shadow 0.28s ease, transform 0.28s ease;
}

.float-notes-card--expanded {
  box-shadow:
    0 12rpx 40rpx rgba(102, 126, 234, 0.12),
    0 0 0 1rpx rgba(102, 126, 234, 0.1);
}

.float-notes-card__head {
  display: flex;
  align-items: center;
  padding: 24rpx 22rpx;
  gap: 20rpx;
  background: linear-gradient(180deg, #fafbff 0%, #ffffff 100%);
}

.float-notes-card__avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background: #eef2f7;
  box-shadow: 0 2rpx 10rpx rgba(15, 23, 42, 0.06);
}

.float-notes-card__meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.float-notes-card__name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  letter-spacing: 0.3rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.float-notes-card__total-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8rpx 12rpx;
}

.float-notes-card__total-label {
  font-size: 24rpx;
  color: #64748b;
}

.float-notes-card__total-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #667eea;
  font-variant-numeric: tabular-nums;
}

.float-notes-card__chev-wrap {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(102, 126, 234, 0.08);
}

.float-notes-card__chev {
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid #667eea;
  border-bottom: 3rpx solid #667eea;
  transform: rotate(-45deg);
  margin-top: -6rpx;
  transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
}

.float-notes-card--expanded .float-notes-card__chev {
  transform: rotate(45deg);
  margin-top: 0;
}

.float-notes-card__body {
  padding: 4rpx 22rpx 24rpx;
  border-top: 1rpx solid rgba(102, 126, 234, 0.08);
  background: #fff;
  animation: float-notes-body-in 0.32s cubic-bezier(0.22, 1, 0.36, 1) both;
}

@keyframes float-notes-body-in {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.float-notes-card__hint {
  padding: 20rpx 4rpx 12rpx;
}

.float-notes-note-wrap {
  max-height: 55vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  margin-top: 8rpx;
  padding: 16rpx 4rpx 12rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.float-notes-mp-html {
  word-break: break-word;
}
