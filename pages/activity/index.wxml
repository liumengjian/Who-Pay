<!--pages/activity/index.wxml - ColorUI -->
<cu-custom bgColor="bg-gradual-blue">
</cu-custom>
<view wx:if="{{showHallDetail || showCreate}}" class="page-blocker" catchtouchmove="preventTouchMove"></view>
<view class="activity-index-frame" style="height:calc(100vh - {{navHeight}}px);">
  <view class="sub-tabs flex bg-white solid-bottom">
    <view class="flex-sub text-center padding {{mainTab === 'hall' ? 'text-blue text-bold' : 'text-gray'}}" bindtap="switchTabHall">活动大厅</view>
    <view class="flex-sub text-center padding {{mainTab === 'mine' ? 'text-blue text-bold' : 'text-gray'}}" bindtap="switchTabMine">我的活动</view>
  </view>
  <swiper
    class="main-tab-swiper"
    current="{{mainTabIndex}}"
    bindchange="onMainTabSwiperChange"
    easing-function="easeOutCubic"
  >
    <swiper-item class="main-tab-swiper-item">
      <scroll-view scroll-y class="refresh-scroll main-tab-scroll" refresherEnabled refresherThreshold="80" refresherTriggered="{{triggered}}" bindrefresherrefresh="onRefresh" bindscrolltolower="onHallScrollToLower" lower-threshold="60">
        <view class="page-bg-gradual">
          <view class="activity-page">
            <view class="activity-list">
              <view class="hall-search cu-bar search bg-white round" wx:if="{{hallActivities.length > 0}}">
                <view class="search-form round">
                  <text class="cuIcon-search text-gray margin-left-sm"></text>
                  <input type="text" placeholder='请输入' value="{{hallSearchKeyword}}" confirm-type="search" bindinput="onHallSearchInput" placeholder-class="text-gray" />
                </view>
              </view>
              <view wx:if="{{hallActivities.length > 0 && hallDisplayList.length > 0}}">
                <view class="cu-card dynamic cu-card-hover animation-scale-up" wx:for="{{hallDisplayList}}" wx:key="id" bindtap="onOpenHallActivity" data-id="{{item.id}}" data-name="{{item.name}}">
                  <view class="cu-item flex padding">
                    <view class="flex-sub">
                      <view class="flex-between margin-bottom-sm align-start">
                        <text class="text-lg text-bold text-black flex-sub">{{item.name}}</text>
                        <view class="flex align-center flex-wrap justify-end">
                          <view class="cu-tag sm round bg-cyan light">{{item.teamCount}} 个团队</view>
                          <view wx:if="{{item.inviteCode}}" class="cu-tag sm round bg-blue light margin-left-sm">邀请码 {{item.inviteCode}}</view>
                        </view>
                      </view>
                      <text class="text-sm text-gray">点击查看团队与成员，凭邀请码加入</text>
                    </view>
                  </view>
                </view>
              </view>
              <view wx:elif="{{hallActivities.length > 0 && hallDisplayList.length === 0}}" class="empty-wrapper">
                <empty-state tip="未找到名称包含「{{hallSearchKeyword}}」的活动" />
              </view>
              <view wx:else class="empty-wrapper">
                <empty-state tip="大厅暂无进行中的活动" />
              </view>
              <view wx:if="{{hallActivities.length > 0 && hallHasMore && hallLoadingMore}}" class="hall-list-footer text-center text-gray text-sm padding-top padding-bottom">加载中…</view>
              <view wx:if="{{hallActivities.length > 0 && !hallHasMore}}" class="hall-list-footer text-center text-gray text-sm padding-top padding-bottom">没有更多了</view>
            </view>
          </view>
        </view>
      </scroll-view>
    </swiper-item>
    <swiper-item class="main-tab-swiper-item">
      <scroll-view scroll-y class="refresh-scroll main-tab-scroll" refresherEnabled refresherThreshold="80" refresherTriggered="{{triggered}}" bindrefresherrefresh="onRefresh">
        <view class="page-bg-gradual">
          <view class="activity-page">
            <view class="activity-list mine-tab-list">
              <view wx:if="{{myActivities.length > 0}}">
                <view
                  class="mine-card"
                  wx:for="{{myActivities}}"
                  wx:key="_id"
                  bindtap="goToDetail"
                  data-id="{{item._id}}"
                >
                  <view class="mine-card-top">
                    <image
                      class="mine-card-avatar"
                      src="{{item.avatarUrl || '/images/default-avatar.png'}}"
                      mode="aspectFill"
                    ></image>
                    <view class="mine-card-body">
                      <text class="mine-card-title">{{item.name}}</text>
                      <text wx:if="{{item.slogan}}" class="mine-card-slogan">{{item.slogan}}</text>
                    </view>
                  </view>
                  <view class="mine-card-teams" wx:if="{{item.teams && item.teams.length > 0}}">
                    <view
                      class="mine-card-team"
                      wx:for="{{item.teams}}"
                      wx:key="id"
                      wx:for-item="team"
                    >
                      <text class="mine-card-team-name">{{team.name}}</text>
                      <view class="mine-card-members">
                        <image
                          wx:for="{{team.members}}"
                          wx:key="userId"
                          wx:for-item="mem"
                          class="mine-card-member-avatar"
                          src="{{mem.avatarUrl || '/images/default-avatar.png'}}"
                          mode="aspectFill"
                        ></image>
                      </view>
                    </view>
                  </view>
                  <view wx:else class="mine-card-empty">暂无团队</view>
                </view>
              </view>
              <view wx:else class="empty-wrapper">
                <empty-state tip="您还没有加入进行中的活动" />
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </swiper-item>
  </swiper>
</view>

<view class="action-bar flex padding bg-white action-bar-active {{showFloatNotesPanel || actionBarAwaitTabBarShow ? 'action-bar--under-modal' : ''}}">
  <button class="cu-btn block flex-sub shadow round action-bar-single activity-create-btn" bindtap="showCreateModal">创建活动</button>
</view>

<!-- 首页笔记入口：右下角悬浮 -->
<view wx:if="{{!showFloatNotesPanel}}" class="float-notes-fab" hover-class="float-notes-fab--hover" hover-stay-time="100" bindtap="openFloatNotesPanel">
  <image class="float-notes-fab__img" src="cloud://prod-4g6txya8d2f21745.7072-prod-4g6txya8d2f21745-1413661498/files/assets/float-icon.png" mode="aspectFit" />
</view>

<!--
  page-container 仅包裹「笔记弹窗」壳层（遮罩 + 居中容器），盖住胶囊；打开前 hideTabBar，afterleave 里 showTabBar。
  弹窗从右下角悬浮按钮方向缩放入场，非底部抽屉。
-->
<page-container
  show="{{showFloatNotesPanel}}"
  position="center"
  round="{{false}}"
  z-index="10001"
  overlay="{{true}}"
  overlay-style="background-color: rgba(15, 23, 42, 0.52);"
  custom-style="{{floatNotesPageContainerStyle}}"
  duration="{{320}}"
  bind:clickoverlay="closeFloatNotesPanel"
  bind:afterleave="onFloatNotesPageContainerAfterLeave"
>
  <view class="float-notes-modal" catchtap="stopPropagation">
    <view class="float-notes-sheet">
      <view class="float-notes-sheet__head">
        <text class="float-notes-sheet__title">我的活动笔记</text>
      </view>
      <view wx:if="{{floatNotesLoading}}" class="float-notes-loading text-gray text-sm">同步活动与笔记中…</view>
      <scroll-view scroll-y class="float-notes-scroll">
        <view wx:if="{{!floatNotesLoading && floatNoteCards.length === 0}}" class="float-notes-empty text-gray text-sm">暂无进行中的活动</view>
        <view
          wx:for="{{floatNoteCards}}"
          wx:key="id"
          class="float-notes-card {{item.expanded ? 'float-notes-card--expanded' : ''}}"
        >
          <view class="float-notes-card__head" bindtap="toggleFloatNoteCard" data-id="{{item.id}}">
            <image class="float-notes-card__avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
            <view class="float-notes-card__meta">
              <text class="float-notes-card__name">{{item.name}}</text>
              <view class="float-notes-card__total-row">
                <text class="float-notes-card__total-label">总花费</text>
                <text class="float-notes-card__total-num">¥{{item.totalAmount}}</text>
              </view>
            </view>
            <view class="float-notes-card__chev-wrap">
              <view class="float-notes-card__chev"></view>
            </view>
          </view>
          <view wx:if="{{item.expanded}}" class="float-notes-card__body">
            <view wx:if="{{!item.detailLoaded}}" class="float-notes-card__hint text-gray text-sm">加载中…</view>
            <view wx:elif="{{item.detailError}}" class="float-notes-card__hint text-gray text-sm">加载失败，请下拉刷新后重试</view>
            <block wx:elif="{{item.noteHasPreview}}">
              <view class="float-notes-note-wrap">
                <mp-html
                  class="float-notes-mp-html note-mp-html"
                  content="{{item.noteContentForHtml}}"
                  container-style="font-size:30rpx;line-height:1.65;color:#333;"
                  tag-style="{{floatNoteMpTagStyle}}"
                  copy-link="{{false}}"
                  preview-img="{{false}}"
                  selectable="{{true}}"
                  data-aid="{{item.id}}"
                  bindlinktap="onFloatNoteLinkTap"
                  bindimgtap="onFloatNoteImgTap"
                />
              </view>
            </block>
            <view wx:else class="float-notes-card__hint text-gray text-sm">暂无笔记，可在活动详情中编辑</view>
          </view>
        </view>
        <view class="float-notes-scroll__foot"></view>
      </scroll-view>
    </view>
    <view
      class="float-notes-modal__close"
      hover-class="float-notes-modal__close--hover"
      hover-stay-time="100"
      catchtap="closeFloatNotesPanel"
    >×</view>
  </view>
</page-container>

<!-- 大厅活动详情弹窗 -->
    <view wx:if="{{showHallDetail}}" class="cu-modal show" catchtap="hideHallDetailModal">
      <view class="cu-dialog hall-dialog animation-scale-up" catchtap="stopPropagation">
        <view class="cu-bar bg-white justify-end">
          <view class="content text-black text-bold">{{hallActivityName || '活动'}}</view>
          <view class="action" bindtap="hideHallDetailModal"><text class="cuIcon-close text-gray"></text></view>
        </view>
        <scroll-view scroll-y class="hall-scroll padding" wx:if="{{!loadingHallPreview && hallPreview}}">
          <view wx:if="{{hallActivityJoined}}" class="margin-bottom-sm">
            <view class="cu-tag bg-green light radius">您已加入该活动</view>
            <button class="cu-btn sm bg-blue margin-top-sm" bindtap="goHallToDetail">进入活动</button>
          </view>
          <view class="text-gray text-sm margin-bottom">团队与成员</view>
          <view wx:for="{{hallPreview.teams}}" wx:key="id" wx:for-item="team" class="margin-bottom">
            <text class="text-bold">{{team.name}}</text>
            <view class="flex flex-wrap margin-top-xs">
              <view wx:for="{{team.members}}" wx:key="userId" wx:for-item="mem" class="hall-member padding-xs" catchtap="goHallMemberProfile" data-uid="{{mem.userId}}">
                <image class="cu-avatar sm round" src="{{mem.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
                <text class="text-xs block text-center margin-top-xs">{{mem.nickName}}</text>
              </view>
            </view>
          </view>
          <view wx:if="{{hallPreview.teams.length === 0}}" class="text-gray text-sm">暂无团队</view>
          <view class="cu-form-group margin-top" wx:if="{{!hallActivityJoined}}">
            <view class="title">活动邀请码</view>
            <input placeholder="6位大写字母或数字" value="{{hallInviteInput}}" bindinput="onHallInviteInput" maxlength="6" placeholder-class="text-gray" />
          </view>
          <view class="hall-dual-actions" wx:if="{{!hallActivityJoined && !hallApplicationSent}}">
            <button class="cu-btn flex-sub bg-blue" bindtap="handleHallJoinActivity">加入活动</button>
            <button class="cu-btn flex-sub bg-green light" bindtap="handleHallApplyActivity">申请加入</button>
          </view>
          <button wx:if="{{!hallActivityJoined && hallApplicationSent}}" class="cu-btn block bg-grey margin-top" disabled>已申请，请等待审批</button>
        </scroll-view>
        <view class="padding" wx:if="{{loadingHallPreview}}"><text class="text-gray">加载中...</text></view>
      </view>
    </view>

    <!-- 创建活动弹窗 -->
    <view wx:if="{{showCreate}}" class="cu-modal show" catchtap="hideCreateModal">
      <view class="cu-dialog animation-scale-up" catchtap="stopPropagation">
        <view class="cu-bar bg-white justify-end">
          <view class="content text-black text-bold">创建活动</view>
          <view class="action" bindtap="hideCreateModal"><text class="cuIcon-close text-gray"></text></view>
        </view>
        <view class="padding">
          <view class="create-avatar-row margin-bottom">
            <button class="avatar-pick-btn" open-type="chooseAvatar" bindchooseavatar="onChooseActivityAvatar">
              <image class="create-act-avatar round" src="{{activityAvatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
              <text class="text-gray text-sm margin-top-xs block text-center">活动头像（默认与您的头像一致）</text>
            </button>
          </view>
          <view class="cu-form-group">
            <view class="title">活动名称</view>
            <input placeholder="必填" value="{{activityName}}" bindinput="onActivityNameInput" maxlength="128" placeholder-class="text-gray" />
          </view>
          <view class="cu-form-group">
            <view class="title">活动宣言</view>
            <textarea placeholder="选填，一句话介绍活动" value="{{activitySlogan}}" bindinput="onActivitySloganInput" maxlength="512" auto-height placeholder-class="text-gray"></textarea>
          </view>
          <view class="invite-friends-row" wx:if="{{enableSocial}}" catchtap="openInviteFriendsModal">
            <text class="invite-friends-label">一键邀请</text>
            <view class="invite-friends-right">
              <text wx:if="{{invitedCount > 0}}" class="invite-friends-count">已选 {{invitedCount}} 位好友</text>
              <text wx:else class="invite-friends-hint">选择好友加入活动</text>
              <text class="cuIcon-right text-gray"></text>
            </view>
          </view>
        </view>
        <view class="cu-bar padding justify-end bg-grey light">
          <button class="cu-btn margin-right-sm" bindtap="hideCreateModal">取消</button>
          <button class="cu-btn bg-blue" bindtap="handleCreate">创建</button>
        </view>
      </view>
    </view>

    <!-- 邀请好友选择弹窗 -->
    <view wx:if="{{enableSocial && showInviteFriends}}" class="cu-modal show" catchtap="hideInviteFriendsModal">
      <view class="cu-dialog invite-dialog" catchtap="stopPropagation">
        <view class="cu-bar bg-white justify-end">
          <view class="content text-black text-bold">邀请好友</view>
          <view class="action" bindtap="hideInviteFriendsModal"><text class="cuIcon-close text-gray"></text></view>
        </view>
        <scroll-view scroll-y class="invite-scroll">
          <view wx:if="{{inviteFriendLoading}}" class="padding text-center text-gray text-sm">加载中...</view>
          <view wx:elif="{{inviteFriendList.length === 0}}" class="padding text-center text-gray text-sm">暂无好友</view>
          <view wx:else>
            <view class="invite-friend-item {{item._selected ? 'invite-friend-selected' : ''}}"
                  wx:for="{{inviteFriendList}}" wx:key="id"
                  catchtap="toggleInviteFriend" data-uid="{{item.id}}">
              <image class="invite-friend-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
              <view class="invite-friend-info">
                <text class="invite-friend-name">{{item.nickName || item.username}}</text>
              </view>
              <view class="invite-friend-check {{item._selected ? 'invite-friend-check-on' : ''}}">
                <text wx:if="{{item._selected}}" class="cuIcon-check"></text>
              </view>
            </view>
          </view>
        </scroll-view>
        <view class="cu-bar padding justify-end bg-grey light">
          <button class="cu-btn margin-right-sm" bindtap="hideInviteFriendsModal">取消</button>
          <button class="cu-btn bg-blue" bindtap="confirmInviteFriends">确认（{{invitedCount}}）</button>
        </view>
      </view>
    </view>