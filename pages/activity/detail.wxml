<!--pages/activity/detail.wxml-->
<view class="page-hero page-hero-detail">
<cu-custom bgColor="bg-hero-transparent" isBack="{{true}}">
</cu-custom>
<scroll-view scroll-y class="refresh-scroll hero-below-nav" style="height:calc(100vh - {{navHeight}}px)" refresherEnabled refresherThreshold="80" refresherTriggered="{{triggered}}" bindrefresherrefresh="onRefresh">
<view class="detail-page">
  <!-- 概览区 -->
  <view class="overview-section">
    <view class="activity-header">
      <view class="activity-header-main">
        <view
          class="activity-avatar-tap {{isCreator && !isEnded ? 'activity-avatar-editable' : ''}}"
          bindtap="onActivityAvatarTap"
        >
          <image
            class="detail-act-avatar round"
            src="{{activityInfo.avatarUrl || '/images/default-avatar.png'}}"
            mode="aspectFill"
          ></image>
          <view wx:if="{{isCreator && !isEnded}}" class="activity-avatar-edit-badge">编辑</view>
        </view>
        <view class="activity-header-text flex-sub">
          <text class="activity-name">{{activityInfo.name || ''}}</text>
          <text wx:if="{{activityInfo.slogan}}" class="activity-slogan">{{activityInfo.slogan}}</text>
        </view>
      </view>
      <view class="invite-code-box" bindtap="copyInviteCode">
        <text class="invite-code">{{activityInfo.inviteCode || ''}}</text>
    <image class="copy-icon" src="/images/copy.png" mode="aspectFit"></image>
      </view>
    </view>
    <view class="amount-info">
      <view class="amount-item">
        <text class="amount-label">总花费</text>
        <text class="amount-value">¥{{totalAmount}}</text>
      </view>
      <view class="amount-item">
        <text class="amount-label">人均花费</text>
        <text class="amount-value">¥{{shareAmount}}</text>
      </view>
    </view>
    
    <!-- 我的结算信息 -->
    <view class="my-settlement" wx:if="{{myTeam}}">
      <view wx:if="{{shareBalancedComplete}}" class="settlement-equalized">
        <view class="settlement-equalized-head">
          <view class="settlement-equalized-dot"></view>
          <text class="settlement-equalized-title">已均摊完成</text>
        </view>
        <text class="settlement-equalized-desc">所有人实付金额与人均应付一致，暂无差额。</text>
      </view>
      <block wx:else>
        <view class="settlement-item team-settlement">
          <text class="settlement-label">您的团队</text>
          <text class="settlement-value {{myTeamDiff >= 0 ? 'positive' : 'negative'}}">
            <text wx:if="{{myTeamDiff < 0}}">需要向其他团队支付</text>
            <text wx:else>可以从其他团队收款</text>
            <text class="amount">¥{{myTeamDiff >= 0 ? myTeamDiff : (-myTeamDiff)}}</text>
          </text>
        </view>
        <view class="settlement-item personal-settlement">
          <text class="settlement-label">您个人</text>
          <text class="settlement-value {{myTeamDiff >= 0 ? 'positive' : 'negative'}}">
            <text wx:if="{{myTeamDiff < 0}}">需要支付</text>
            <text wx:else>可以收款</text>
            <text class="amount">¥{{myPersonalDiff}}</text>
          </text>
        </view>
      </block>
    </view>

    <view class="equalize-row" wx:if="{{showEqualizeBtn}}">
      <button class="equalize-btn" bindtap="handleEqualizeShare">一键均摊</button>
      <text class="equalize-hint">截止到今天之前的消费已线下均摊完成后执行</text>
    </view>
  </view>

  <!-- 团队看板 -->
  <view class="teams-section">
    <view wx:if="{{teams.length === 0 && !isEnded}}" class="teams-empty-hint text-gray text-sm padding-lr margin-bottom-sm">
      暂无团队，点击右下角 + 创建团队
    </view>
    <view 
      class="team-card {{!myTeam && !team.iCreated && !team.amMember ? 'team-card-joinable' : ''}}" 
      wx:for="{{teams}}" 
      wx:key="_id"
      wx:for-item="team"
      bindtap="onTeamCardTap"
      data-id="{{team._id}}"
    >
      <view class="team-header">
        <view class="team-title-block flex-sub">
          <text class="team-name">{{team.name}}</text>
          <view wx:if="{{team.iCreated && team.inviteCode}}" class="team-card-invite-row" catchtap="onCopyTeamCardInvite" data-code="{{team.inviteCode}}">
            <text class="team-invite-label">团队邀请码</text>
            <text class="team-invite-code-text">{{team.inviteCode}}</text>
    <image class="copy-icon" src="/images/copy.png" mode="aspectFit"></image>
          </view>
          <text wx:if="{{!myTeam && !team.iCreated && !team.amMember}}" class="team-tap-hint">点此输入邀请码加入</text>
        </view>
        <view class="team-stats">
          <text class="team-total">支付: ¥{{team.totalAmount}}</text>
          <text class="team-diff {{team.diffAmount >= 0 ? 'positive' : 'negative'}}">
            {{team.diffAmount >= 0 ? '应收' : '应付'}}: ¥{{team.diffAmount >= 0 ? team.diffAmount : (-team.diffAmount)}}
          </text>
          <text class="team-member-share" wx:if="{{team.memberCount > 0}}">
          </text>
        </view>
      </view>
      <view class="members-list">
        <view 
          class="member-item" 
          wx:for="{{team.members}}" 
          wx:key="userId"
          wx:for-item="member"
          catchtap="viewMemberPayments"
          data-userid="{{member.userId}}"
        >
          <image class="member-avatar" src="{{member.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="member-info">
            <text class="member-name">{{member.nickName}}</text>
            <text class="member-amount">¥{{member.totalAmount}}</text>
          </view>
        </view>
        <view wx:if="{{team.members.length === 0}}" class="empty-members">
          <text>暂无成员</text>
        </view>
      </view>
      <view wx:if="{{team.iCreated && !isEnded}}" class="team-card-owner-row" catchtap="stopPropagation">
        <text class="team-owner-action" catchtap="handleEditTeamTap" data-id="{{team._id}}" data-name="{{team.name}}">修改团队</text>
        <text class="team-owner-action danger" catchtap="handleDissolveTeamTap" data-id="{{team._id}}">解散团队</text>
      </view>
    </view>
  </view>

  <!-- 费用明细筛选区 -->
  <view class="expense-section">
    <view class="expense-header" bindtap="openExpenseDetail">
      <view class="expense-title">
        <text class="section-title-text">费用明细</text>
        <text class="expense-hint">按日期查看</text>
      </view>
      <text class="expense-arrow">›</text>
    </view>
  </view>

  <view class="extra-actions padding-sm" wx:if="{{!isEnded && myTeam && !isTeamCreator}}">
    <button class="link-btn" bindtap="handleLeaveTeam">退出团队</button>
  </view>

</view>
</scroll-view>
</view>

<!-- 底部操作栏：+ 记账；创建者-结束活动 / 非创建者-退出活动 -->
<view class="action-bar" wx:if="{{!isEnded}}">
  <button class="add-btn" bindtap="handlePrimaryFab">+</button>
  <button wx:if="{{isCreator}}" class="bar-danger-btn" bindtap="handleEndActivity">结束活动</button>
  <button wx:if="{{!isCreator}}" class="bar-danger-btn" bindtap="handleLeaveActivity">退出活动</button>
</view>

<!-- 加入团队（邀请码）；wx:if 避免 iOS 原生 input placeholder 穿透 -->
  <view wx:if="{{showJoinTeamModal}}" class="modal show" catchtap="hideJoinTeamModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title">加入团队<text wx:if="{{joinTeamHintName}}">「{{joinTeamHintName}}」</text></view>
        <text class="modal-close" bindtap="hideJoinTeamModal">×</text>
      </view>
      <view class="modal-body">
        <text class="text-gray text-sm block margin-bottom-sm">请输入该团队的 6 位邀请码</text>
        <view class="input-group">
          <text class="input-label">邀请码 <text class="required">*</text></text>
          <input
            class="input"
            type="text"
            placeholder="输入邀请码可直接加入"
            value="{{teamInviteCode}}"
            bindinput="onTeamInviteInput"
            maxlength="6"
          />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-apply" bindtap="handleJoinTeamApply">申请加入</button>
        <button class="btn-primary" bindtap="handleJoinTeamByInvite">加入团队</button>
      </view>
    </view>
  </view>

  <!-- 创建团队成功：邀请码（可分享给成员） -->
  <view wx:if="{{showTeamInviteResult}}" class="modal show" catchtap="hideTeamInviteResult">
    <view class="modal-content team-invite-result-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">团队创建成功</text>
        <text class="modal-close" bindtap="hideTeamInviteResult">×</text>
      </view>
      <view class="modal-body align-center">
        <text class="text-gray text-sm margin-bottom-sm">团队邀请码（分享给成员即可加入）</text>
        <view class="created-invite-code-box" bindtap="copyCreatedTeamInvite">
          <text class="created-invite-code">{{createdTeamInviteCode}}</text>
    <image class="copy-icon" src="/images/copy.png" mode="aspectFit"></image>
        </view>
        <button class="btn-primary margin-top-lg block" bindtap="hideTeamInviteResult">完成</button>
      </view>
    </view>
  </view>

  <!-- 编辑活动（头像/名称/宣言，仅创建者） -->
  <view wx:if="{{showEditActivity}}" class="modal show" catchtap="hideEditActivityModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">编辑活动</text>
        <text class="modal-close" bindtap="hideEditActivityModal">×</text>
      </view>
      <view class="modal-body">
        <view class="edit-act-avatar margin-bottom">
          <button class="avatar-pick-btn-round" open-type="chooseAvatar" bindchooseavatar="onChooseEditActivityAvatar">
            <image class="edit-act-avatar-img round" src="{{editActivityAvatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
            <text class="text-gray text-sm block margin-top-xs text-center">点击更换头像</text>
          </button>
        </view>
        <view class="input-group">
          <text class="input-label">活动名称 <text class="required">*</text></text>
          <input
            class="input"
            type="text"
            placeholder="活动名称"
            value="{{editActivityName}}"
            bindinput="onEditActivityNameInput"
            maxlength="128"
          />
        </view>
        <view class="input-group">
          <text class="input-label">活动宣言</text>
          <textarea
            class="input area"
            placeholder="一句话介绍"
            value="{{editActivitySlogan}}"
            bindinput="onEditActivitySloganInput"
            maxlength="512"
            auto-height
          ></textarea>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="hideEditActivityModal">取消</button>
        <button class="btn-primary" bindtap="handleSaveActivityInfo">保存</button>
      </view>
    </view>
  </view>

  <!-- 修改团队名称 -->
  <view wx:if="{{showEditTeamNameModal}}" class="modal show" catchtap="hideEditTeamNameModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">修改团队名称</text>
        <text class="modal-close" bindtap="hideEditTeamNameModal">×</text>
      </view>
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">团队名称 <text class="required">*</text></text>
          <input
            class="input"
            type="text"
            placeholder="团队名称"
            value="{{editTeamNameInput}}"
            bindinput="onEditTeamNameInputModal"
            maxlength="128"
          />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="hideEditTeamNameModal">取消</button>
        <button class="btn-primary" bindtap="handleSaveTeamName">保存</button>
      </view>
    </view>
  </view>

  <!-- 创建团队弹窗 -->
  <view wx:if="{{showCreateTeam}}" class="modal show" catchtap="hideCreateTeamModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">创建新团队</text>
        <text class="modal-close" bindtap="hideCreateTeamModal">×</text>
      </view>
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">团队名称 <text class="required">*</text></text>
          <input 
            class="input" 
            type="text" 
            placeholder="请输入团队名称"
            value="{{teamName}}"
            bindinput="onTeamNameInput"
            maxlength="20"
          />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="hideCreateTeamModal">取消</button>
        <button class="btn-primary" bindtap="handleCreateTeam">创建</button>
      </view>
    </view>
  </view>

  <!-- 添加支付记录弹窗 -->
  <view wx:if="{{showAddPayment}}" class="modal show" catchtap="hideAddPaymentModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">添加支付记录</text>
        <text class="modal-close" bindtap="hideAddPaymentModal">×</text>
      </view>
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">金额 <text class="required">*</text></text>
          <input 
            class="input" 
            type="digit" 
            placeholder="请输入金额"
            value="{{paymentAmount}}"
            bindinput="onPaymentAmountInput"
          />
        </view>
        <view class="input-group">
          <text class="input-label">备注</text>
          <input 
            class="input" 
            type="text" 
            placeholder="选填"
            value="{{paymentRemark}}"
            bindinput="onPaymentRemarkInput"
            maxlength="50"
          />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="hideAddPaymentModal">取消</button>
        <button class="btn-primary" bindtap="handleAddPayment">确定</button>
      </view>
    </view>
  </view>

  <!-- 成员支付记录弹窗 -->
  <view wx:if="{{showMemberPayments}}" class="modal show" catchtap="hideMemberPayments">
    <view class="modal-content payment-list-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{selectedMemberName}}的支付记录</text>
        <text class="modal-close" bindtap="hideMemberPayments">×</text>
      </view>
      <view class="expense-hint-bar" wx:if="{{selectedMemberId && userId && selectedMemberId === userId}}">
        <text class="expense-hint-text">长按可删除自己的记录</text>
      </view>
      <view class="modal-body">
        <view wx:if="{{memberPayments.length > 0}}">
          <view 
            class="payment-item {{selectedMemberId === userId ? 'payment-item-deletable' : ''}}" 
            wx:for="{{memberPayments}}" 
            wx:key="_id"
            bindlongpress="onMemberPaymentLongPress"
            data-payment-id="{{item._id}}"
            data-amount="{{item.amount}}"
            data-remark="{{item.remark}}"
          >
            <view class="payment-info">
              <text class="payment-amount">¥{{item.amount}}</text>
              <text class="payment-remark" wx:if="{{item.remark}}">{{item.remark}}</text>
            </view>
            <text class="payment-time">{{item.createTime}}</text>
          </view>
        </view>
        <view wx:else class="empty-payments">
          <text>暂无支付记录</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 费用明细弹窗 -->
  <view wx:if="{{showExpenseDetail}}" class="modal show expense-modal" catchtap="hideExpenseDetail">
    <view class="modal-content expense-modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">费用明细</text>
        <text class="modal-close" bindtap="hideExpenseDetail">×</text>
      </view>
      <view class="expense-hint-bar">
        <text class="expense-hint-text">长按可删除记录</text>
      </view>
      <!-- 日期选择器 -->
      <scroll-view class="date-picker" scroll-x enable-flex>
        <view class="date-tabs">
          <view 
            class="date-tab {{selectedDate === item.date ? 'active' : ''}}"
            wx:for="{{dailyExpenseSummary}}"
            wx:key="date"
            bindtap="onDateSelect"
            data-date="{{item.date}}"
          >
            <text class="date-tab-day">{{item.date}}</text>
            <text class="date-tab-amount">¥{{item.total}}</text>
            <text class="date-tab-perperson">人均¥{{item.perPerson}}</text>
          </view>
        </view>
      </scroll-view>
      <!-- 费用列表 -->
      <view class="modal-body expense-list-body">
        <view wx:if="{{expenseList.length > 0}}">
          <view 
            class="expense-item" 
            wx:for="{{expenseList}}" 
            wx:key="_id"
            bindlongpress="onExpenseItemLongPress"
            data-item="{{item}}"
          >
            <view class="expense-left">
              <image class="expense-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
              <view class="expense-info">
                <text class="expense-name">{{item.payerName}}</text>
                <text class="expense-remark" wx:if="{{item.remark}}">{{item.remark}}</text>
                <text class="expense-time">{{item.createTime}}</text>
              </view>
            </view>
            <text class="expense-amount">¥{{item.amount}}</text>
          </view>
        </view>
        <view wx:else class="empty-expenses">
          <text>暂无支付记录</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 删除支付记录确认弹窗 -->
  <view wx:if="{{showDeletePayment}}" class="modal show" catchtap="hideDeletePayment">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">删除支付记录</text>
        <text class="modal-close" bindtap="hideDeletePayment">×</text>
      </view>
      <view class="modal-body">
        <text class="text-gray text-sm block">确定要删除这条支付记录吗？</text>
        <view class="delete-payment-info margin-top">
          <text class="text-bold">¥{{deletePaymentAmount}}</text>
          <text class="text-gray text-sm margin-left-sm" wx:if="{{deletePaymentRemark}}">{{deletePaymentRemark}}</text>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="hideDeletePayment">取消</button>
        <button class="btn-danger" bindtap="confirmDeletePayment">删除</button>
      </view>
    </view>
  </view>
