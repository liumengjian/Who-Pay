{
  "cloud": true,
  "usingComponents": {
    "cu-custom": "/colorui/components/cu-custom"
  },
  "pages": [
    "pages/activity/index",
    "pages/user/profile"
  ],
  "subPackages": [
    {
      "root": "pages/login",
      "name": "login",
      "pages": ["login"]
    },
    {
      "root": "packageActivity",
      "name": "activity-ext",
      "pages": ["detail/detail", "note/note"]
    },
    {
      "root": "packagePayment",
      "name": "payment",
      "pages": ["manage/manage", "history/history"]
    },
    {
      "root": "packageHistory",
      "name": "history",
      "pages": ["list/list", "detail/detail"]
    },
    {
      "root": "packageNotification",
      "name": "notification",
      "pages": ["index/index", "publish/publish", "detail/detail"]
    },
    {
      "root": "packageFriend",
      "name": "friend",
      "pages": ["list/list", "add/add", "home/home", "edit/edit", "album/album"]
    },
    {
      "root": "packageChat",
      "name": "chat",
      "pages": ["list/list", "detail/detail"]
    }
  ],
  "preloadRule": {
    "pages/activity/index": {
      "network": "all",
      "packages": ["login", "activity-ext"]
    },
    "pages/user/profile": {
      "network": "all",
      "packages": ["history", "payment", "notification", "friend", "chat"]
    }
  },
  "window": {
    "backgroundTextStyle": "dark",
    "navigationBarBackgroundColor": "#667eea",
    "navigationBarTitleText": "Who Pay",
    "navigationBarTextStyle": "white",
    "enablePullDownRefresh": true,
    "backgroundColor": "#f7f8fa"
  },
  "tabBar": {
    "color": "#909399",
    "selectedColor": "#667eea",
    "borderStyle": "white",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/activity/index",
        "iconPath": "images/home.png",
        "selectedIconPath": "images/home-active.png",
        "text": ""
      },
      {
        "pagePath": "pages/user/profile",
        "iconPath": "images/user.png",
        "selectedIconPath": "images/user-active.png",
        "text": ""
      }
    ]
  },
  "style": "v2",
  "sitemapLocation": "sitemap.json",
  "requiredPrivateInfos": [
    "getFuzzyLocation",
    "chooseLocation"
  ],
  "permission": {
    "scope.userFuzzyLocation": {
      "desc": "用于在笔记中选择地点时的地图定位"
    }
  }
}
