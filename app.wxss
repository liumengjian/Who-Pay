/**app.wxss - Who Pay 全局样式 */
@import "colorui/main.wxss";
@import "colorui/icon.wxss";
@import "colorui/animation.wxss";

/* ==================
   年轻活泼主题变量覆盖
 ==================== */
page {
  --blue: #667eea;
  --gradualBlue: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --gradualPink: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  --gradualGreen: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  --gradualOrange: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  background: #f7f8fa;
  font-size: 28rpx;
  color: #333;
}

/* 过渡动画 - 交互反馈 */
.cu-transition {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 按钮点击反馈 - 轻量 opacity，避免界面抖动 */
.cu-btn:active, button:active {
  opacity: 0.85;
}

/* 通用按钮样式 - 与 cu-btn 一致 */
.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 12rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.btn-secondary::after, .btn-primary::after,
.add-btn::after, .end-btn::after, .logout-btn::after, .option-btn::after { border: none; }

/* 弹窗/模态框内按钮统一样式 */
.modal-footer button, .modal .cu-bar button {
  font-size: 30rpx;
}

/* 布局 */
.container {
  padding: 24rpx;
}

.flex { display: flex; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-column { display: flex; flex-direction: column; }
.flex-sub { flex: 1; }
.text-center { text-align: center; }
.text-cut { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* 页面头部统一样式 - 与 cu-custom-nav 渐变连贯 */
.page-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 48rpx 40rpx;
  margin-top: -16rpx; /* 重叠 cu-custom 底部，消除断层 */
  margin-bottom: 24rpx;
  color: #fff;
}

.page-header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.page-header-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
