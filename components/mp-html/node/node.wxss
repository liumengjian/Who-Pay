._a{font-weight: 400 !important; font-size: 13px !important; margin: 0 4px;background: #f0f1ff; display:inline-block !important;padding:6px 12px;border:1px dashed #f0f1ff;border-radius: 20px; color:#366092;word-break:break-all}._hover{text-decoration:underline;opacity:.7}
/* 活动笔记芯片：内联常被裁成只剩字色；用 data-* + class 双兜底，display 须 !important 压过内联 display:inline */
[data-chip-type='loc'],[data-note-type='location'],._a.note-chip-loc,.note-chip-loc{display:inline-block!important;vertical-align:middle!important;padding:6px 14px!important;border-radius:12px!important;margin:5px 0!important;background-color:#fafafa!important;box-shadow:0 1px 0 rgba(15,23,42,0.06)!important;border:1px dashed rgba(99,102,241,0.35)!important;color:#3730a3!important;font-size:15px!important;font-weight:600!important;line-height:1.45!important;text-decoration:none!important;word-break:normal!important}
[data-chip-type='att'],[data-note-type='attachment'],._a.note-chip-att,.note-chip-att{display:inline-block!important;vertical-align:middle!important;padding:6px 14px!important;border-radius:12px!important;margin:5px 0!important;background:linear-gradient(180deg,#fff 0%,#f0f9ff 100%)!important;box-shadow:0 1px 4px rgba(14,165,233,0.12),0 0 0 1px rgba(14,165,233,0.25)!important;color:#0369a1!important;font-size:15px!important;font-weight:600!important;line-height:1.45!important;text-decoration:none!important;word-break:normal!important}
._a.note-loc-tag--mp-preview,.note-loc-tag--mp-preview{display:inline-block!important;vertical-align:middle!important;padding:4px 12px!important;border-radius:10px!important;margin:5px!important;background-color:#fff!important;box-shadow:0 1px 4px rgba(15,23,42,0.06),0 0 0 1px rgba(99,102,241,0.16)!important;color:#4f46e5!important;font-size:13px!important;font-weight:600!important;line-height:1.45!important;text-decoration:none!important;word-break:normal!important}
._a.note-loc-tag--mp-read,.note-loc-tag--mp-read{display:inline-block!important;vertical-align:middle!important;padding:6px 14px!important;border-radius:12px!important;margin:5px!important;background-color:#fafafa!important;box-shadow:0 1px 0 rgba(15,23,42,0.06)!important;border:1px dashed rgba(99,102,241,0.35)!important;color:#3730a3!important;font-size:14px!important;font-weight:600!important;line-height:1.45!important;text-decoration:none!important;word-break:normal!important}
._a.note-loc-tag--editor,.note-loc-tag--editor{display:inline-block!important;vertical-align:middle!important;padding:8px 16px!important;border-radius:14px!important;margin:5px!important;background:linear-gradient(180deg,#fff 0%,#f8fafc 100%)!important;box-shadow:0 2px 10px rgba(15,23,42,0.06),0 0 0 1px rgba(99,102,241,0.22)!important;color:#4338ca!important;font-size:14px!important;font-weight:600!important;line-height:1.45!important;text-decoration:none!important;word-break:normal!important}
._a.note-attach-tag--chip,.note-attach-tag--chip{display:inline-block!important;vertical-align:middle!important;padding:8px 16px!important;border-radius:14px!important;margin:10px 0!important;background:linear-gradient(180deg,#fff 0%,#f0f9ff 100%)!important;box-shadow:0 2px 10px rgba(14,165,233,0.08),0 0 0 1px rgba(14,165,233,0.28)!important;color:#0369a1!important;font-size:14px!important;font-weight:600!important;line-height:1.45!important;text-decoration:none!important;word-break:normal!important}
._img{max-width:100%;-webkit-touch-callout:none}._b,._strong{font-weight:700}._code{font-family:monospace}._del{text-decoration:line-through}._em,._i{font-style:italic}._h1{font-size:2em}._h2{font-size:1.5em}._h3{font-size:1.17em}._h5{font-size:.83em}._h6{font-size:.67em}._h1,._h2,._h3,._h4,._h5,._h6{display:block;font-weight:700}._ins{text-decoration:underline}._li{display:list-item}._ol{list-style-type:decimal}._ol,._ul{display:block;padding-left:40px;margin:1em 0}._q::before{content:'"'}._q::after{content:'"'}._sub{font-size:smaller;vertical-align:sub}._sup{font-size:smaller;vertical-align:super}._tbody,._tfoot,._thead{display:table-row-group}._tr{display:table-row}._td,._th{display:table-cell;vertical-align:middle}._th{font-weight:700;text-align:center}._ul{list-style-type:disc}._ul ._ul{margin:0;list-style-type:circle}._ul ._ul ._ul{list-style-type:square}._abbr,._b,._code,._del,._em,._i,._ins,._label,._q,._span,._strong,._sub,._sup{display:inline}._blockquote,._div,._p{display:block}