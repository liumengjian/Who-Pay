.chat-detail-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f7f8fa;
}

.nav-title-white {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.nav-title-ellipsis {
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.container {
  display: flex;
  flex-direction: column;
  width: 100%;
  min-height: 0;
  background: #f7f8fa;
}

.messages {
  flex-shrink: 0;
  padding: 20rpx;
  box-sizing: border-box;
}

.load-hint {
  text-align: center;
  font-size: 24rpx;
  color: #909399;
  padding: 16rpx 0;
}

.msg-list {
  padding-bottom: 20rpx;
}

.msg-item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.msg-item.sent {
  flex-direction: row-reverse;
}

.msg-item.received {
  flex-direction: row;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.bubble-wrap {
  max-width: 72%;
}

.bubble {
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-all;
}

.sent .bubble {
  background: #667eea;
  color: #fff;
  margin-right: 20rpx;
}

.received .bubble {
  background: #fff;
  color: #333;
  margin-left: 20rpx;
}

.bubble-text {
  color: inherit;
}

.bubble-img {
  max-width: 360rpx;
  display: block;
  border-radius: 8rpx;
}

.bubble-card {
  min-width: 200rpx;
}
.bubble-card-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 8rpx;
}

.bubble-card-title {
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.bubble-card-sub {
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 8rpx;
  display: block;
}

.bubble-card-tip {
  font-size: 22rpx;
  margin-top: 10rpx;
  opacity: 0.75;
  display: block;
}

.input-bar-container {
  flex-shrink: 0;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx 12rpx 12rpx;
}

.plus-btn {
  width: 64rpx;
  height: 64rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  background: #f0f2f8;
  color: #667eea;
  font-size: 44rpx;
  line-height: 60rpx;
  text-align: center;
  flex-shrink: 0;
}

.input {
  flex: 1;
  height: 64rpx;
  padding: 0 16rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.send-btn {
  padding: 0 28rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin-left: 12rpx;
  background: #667eea;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  flex-shrink: 0;
}

.extra-bar {
  padding: 16rpx 20rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.extra-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.extra-cell {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 20rpx 20rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.extra-icon {
  display: block;
  width: 46rpx;
  height: 46rpx;
}

.extra-label {
  font-size: 22rpx;
  color: #606266;
}
