/* 导航栏 - 与页面主体渐变连贯，无断层 */
.cu-custom-nav {
  margin: 0;
}

/* 渐变类时确保背景与页面容器一致 */
.cu-custom-nav.bg-gradual-blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 铺在父级 .page-hero 上的渐变，导航仅透明叠放，避免与正文各画一遍渐变产生接缝 */
.cu-custom-nav.bg-hero-transparent {
  background: transparent !important;
  color: #ffffff;
}

.cu-custom-nav.bg-hero-transparent .cu-bar {
  background: transparent !important;
}
