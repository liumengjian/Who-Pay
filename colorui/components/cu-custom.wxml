<view class="cu-custom cu-custom-nav {{bgColor || 'bg-white'}}" style="height:{{NavHeight + 16}}px; padding-top:{{StatusBar}}px;">
  <view class="cu-bar"  style="height:{{CustomBar}}px;">
    <view wx:if="{{isBack}}" class="action" bindtap="BackPage">
      <text class="cuIcon-back"></text>
    </view>
    <view class="content" style="top:0;">
      <!-- <slot name="content"></slot> -->
    </view>
    <slot name="right"></slot>
  </view>
</view>
