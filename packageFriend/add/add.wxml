<cu-custom bgColor="bg-gradual-blue" isBack="{{true}}">
  <view slot="content" class="nav-title-white">添加好友</view>
</cu-custom>
<scroll-view class="add-scroll" scroll-y style="height: calc(100vh - {{navHeight}}px)">
  <view class="container">
    <view class="content">
      <view class="search-box">
        <input class="search-input" placeholder="搜索用户名或昵称" bindinput="onInput" bindconfirm="search" />
        <view class="search-btn" bindtap="search">搜索</view>
      </view>

      <view class="result-list" wx:if="{{results.length > 0}}">
        <view class="result-item" wx:for="{{results}}" wx:key="id">
          <image class="avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="info">
            <text class="nickname">{{item.nickName || item.username}}</text>
            <text class="username">@{{item.username}}</text>
          </view>
          <button class="add-btn" bindtap="goProfile" data-id="{{item.id}}">查看</button>
        </view>
      </view>

      <view class="empty" wx:elif="{{searched}}">
        <text>未找到用户</text>
      </view>
    </view>
  </view>
</scroll-view>
