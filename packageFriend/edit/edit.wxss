.page-edit-body {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: #f7f8fa;
}

.page-edit-scroll {
  flex: 1;
  min-height: 0;
}

.nav-title-white {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.list {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.row:last-child {
  border-bottom: none;
}

.row-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #606266;
  flex-shrink: 0;
}

.row-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-height: 72rpx;
}

.avatar-sm {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
}

.input-plain {
  text-align: right;
  font-size: 28rpx;
  width: 100%;
}

.t-dark {
  color: #333;
}
.t-ph {
  color: #c0c4cc;
}

.row-body-bg {
  justify-content: flex-end;
  gap: 20rpx;
}

.bg-preview {
  width: 140rpx;
  height: 88rpx;
  border-radius: 10rpx;
  background: #eee;
}

.bg-clear {
  font-size: 34rpx;
  color: #909399;
  padding: 8rpx 12rpx 8rpx 0;
  flex-shrink: 0;
}

.bottom-bar {
  flex-shrink: 0;
  padding: 12rpx;
}

.save-btn {
  width: 100%;
  height: 76rpx;
  line-height: 48rpx;
  background: #667eea;
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
}

/* 修改密码抽屉 */
.pwd-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s, visibility 0.25s;
}

.pwd-mask-show {
  opacity: 1;
  visibility: visible;
}

.pwd-drawer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.25s ease-out;
  padding-bottom: env(safe-area-inset-bottom);
}

.pwd-drawer-show {
  transform: translateY(0);
}

.pwd-drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.pwd-drawer-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #303133;
}

.pwd-drawer-close {
  font-size: 44rpx;
  color: #909399;
  padding: 0 8rpx;
  line-height: 1;
}

.pwd-drawer-body {
  padding: 32rpx 32rpx 40rpx;
}

.pwd-field {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.pwd-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #606266;
  flex-shrink: 0;
}

.pwd-input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.pwd-eye {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-left: 12rpx;
  opacity: 0.35;
  transition: opacity 0.15s;
}

.pwd-eye-on {
  opacity: 0.85;
}

.pwd-submit-btn {
  width: 100%;
  height: 80rpx;
  line-height: 52rpx;
  background: #667eea;
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
  margin-top: 16rpx;
}

.pwd-submit-btn[disabled] {
  background: #b0b8e0;
}

.pwd-link {
  flex-shrink: 0;
  text-align: center;
  padding: 24rpx 32rpx calc(env(safe-area-inset-bottom));
  font-size: 26rpx;
  color: #e74c3c;
}
