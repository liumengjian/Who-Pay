/* pages/activity/detail.wxss - ColorUI 年轻活泼 */

page {
  background: var(--gradualBlue);
}

/* 与 profile/login 相同：整页一条主题渐变，导航透明叠放 */
.page-hero-detail {
  background: var(--gradualBlue);
  min-height: 100vh;
  box-sizing: border-box;
}

/* scroll-view 下拉刷新容器 */
.refresh-scroll {
  overflow: hidden;
}

.refresh-scroll.hero-below-nav {
  background: transparent;
}

.detail-page {
  padding-bottom: 120rpx;
  /* 紫色由 .page-hero-detail 绘制，此处仅过渡到灰底 */
  background: linear-gradient(
    to bottom,
    transparent 0,
    transparent 280rpx,
    #f7f8fa 400rpx,
    #f7f8fa 100%
  );
}

/* 概览区文字叠在父级渐变上 */
.overview-section {
  background: transparent;
  padding: 48rpx 40rpx;
  color: #fff;
  margin-top: -16rpx;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
  gap: 16rpx;
}

.activity-header-main {
  display: flex;
  align-items: flex-start;
  flex: 1;
  min-width: 0;
}

.activity-avatar-tap {
  position: relative;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.activity-avatar-editable .detail-act-avatar {
  border-color: rgba(255, 255, 255, 0.75);
}

.activity-avatar-edit-badge {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  font-size: 18rpx;
  background: rgba(0, 0, 0, 0.45);
  color: #fff;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  line-height: 1.2;
}

.detail-act-avatar {
  width: 100rpx;
  height: 100rpx;
  display: block;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.edit-act-avatar {
  display: flex;
  justify-content: center;
}

.avatar-pick-btn-round {
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  line-height: 1.4;
}

.avatar-pick-btn-round::after {
  border: none;
}

.edit-act-avatar-img {
  width: 140rpx;
  height: 140rpx;
  display: block;
  margin: 0 auto;
}

.input.area {
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
}

.team-card-owner-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx 28rpx;
  padding-top: 20rpx;
  margin-top: 8rpx;
  border-top: 2rpx solid #f0f0f0;
}

.team-owner-action {
  font-size: 26rpx;
  color: #667eea;
  padding: 8rpx 4rpx;
}

.team-owner-action.danger {
  color: #e54d42;
}

.activity-header-text {
  min-width: 0;
  white-space: nowrap;
}

.activity-name {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
}

.activity-slogan {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 12rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 12px;
}
.invite-code-box-container {
  width: 100px;
}

.invite-code-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 12rpx 25rpx;
  border-radius: 8rpx;
}

.invite-code {
  font-size: 28rpx;
}

.invite-code-box .copy-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.share-btn {
  margin-top: 12rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 8rpx;
  padding: 0 24rpx;
  text-align: center;
  width: 100px !important;
}

.share-btn::after {
  border: none;
}

.amount-info {
  display: flex;
  justify-content: space-around;
}

.amount-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.amount-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
}

.amount-value {
  font-size: 48rpx;
  font-weight: bold;
}

.team-invite-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  opacity: 0.95;
}

.invite-code-small {
  margin-left: 16rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.copy-hint {
  margin-left: 12rpx;
}

.extra-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  justify-content: center;
  background: #f7f8fa;
}

.link-btn {
  font-size: 26rpx;
  color: #667eea;
  background: transparent;
  border: none;
  padding: 12rpx 24rpx;
}

.link-btn::after {
  border: none;
}

/* 我的结算信息：浅色底 + 深字，避免叠在灰白渐变上白字不可见 */
.my-settlement {
  margin-top: 30rpx;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
  color: #333;
}

.settlement-equalized {
  text-align: center;
  padding: 8rpx 8rpx 4rpx;
}

.settlement-equalized-head {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.settlement-equalized-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #22c55e;
  flex-shrink: 0;
  box-shadow: 0 0 0 6rpx rgba(34, 197, 94, 0.22);
}

.settlement-equalized-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #15803d;
  letter-spacing: 0.5rpx;
}

.settlement-equalized-desc {
  display: block;
  font-size: 26rpx;
  color: #57534e;
  line-height: 1.55;
  text-align: center;
}

.settlement-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.settlement-item:last-child {
  margin-bottom: 0;
}

.settlement-label {
  font-size: 28rpx;
  color: #666;
  opacity: 1;
}

.settlement-value {
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #333;
}

.settlement-value.positive {
  color: #16a34a;
}

.settlement-value.negative {
  color: #ca8a04;
}

.settlement-value .amount {
  font-size: 32rpx;
}

.equalize-row {
  margin-top: 28rpx;
  padding: 24rpx 28rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
}

.equalize-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #667eea;
  background: #fff;
  border-radius: 40rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.35);
  padding: 0;
  margin: 0;
}

.equalize-btn::after {
  border: none;
}

.equalize-hint {
  font-size: 22rpx;
  color: #666;
  opacity: 1;
  margin-top: 24rpx;
  line-height: 1.45;
  width: 100%;
  display: flex;
  justify-content: center;
}

/* 团队看板 */
.teams-section {
  padding: 20rpx;
}

.team-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.12);
  transition: transform 0.2s ease;
}

.team-card-joinable {
  border: 2rpx dashed rgba(102, 126, 234, 0.55);
}

.teams-empty-hint {
  line-height: 1.5;
  height: 50vh;
  display: flex;
  align-items: center;
  justify-content: center
}

.team-title-block {
  min-width: 0;
  margin-right: 16rpx;
}

.team-card-invite-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: linear-gradient(90deg, #eef2ff 0%, #f5f3ff 100%);
  border-radius: 12rpx;
  font-size: 24rpx;
}

.team-invite-label {
  color: #666;
  margin-right: 12rpx;
}

.team-invite-code-text {
  font-weight: bold;
  color: #667eea;
  letter-spacing: 2rpx;
  margin-right: 8rpx;
}

.team-tap-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}

.team-invite-result-content .align-center {
  text-align: center;
}

.created-invite-code-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #eef2ff 0%, #faf5ff 100%);
  border-radius: 16rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.25);
}

.created-invite-code {
  font-size: 44rpx;
  font-weight: bold;
  color: #5b21b6;
  letter-spacing: 6rpx;
  margin-bottom: 16rpx;
}

.team-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.team-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.team-stats {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.team-total {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.team-member-share {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.team-diff {
  font-size: 28rpx;
  font-weight: bold;
}

.team-diff.positive {
  color: #667eea;
}

.team-diff.negative {
  color: #f59e0b;
}

.members-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.copy-icon {
  width: 36rpx;
  height: 36rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background-color: #f8f9fe;
  border-radius: 12rpx;
  transition: background 0.2s ease;
}

.member-item:active {
  background-color: #eef1fc;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 4rpx;
}

.member-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.member-name {
  font-size: 28rpx;
  color: #333;
}

.member-weight-tag {
  font-size: 22rpx;
  color: #667eea;
  background: #eef1fc;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.member-weight-gear {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #909399;
  flex-shrink: 0;
  margin-left: 8rpx;
  border-radius: 50%;
}

.member-weight-gear:active {
  background: #e8e8e8;
}

.member-amount {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
}

.empty-members {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 24rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 20rpx 40rpx 20rpx;
  gap: 80rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.add-btn {
  width: 320rpx !important;
  height: 80rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 36rpx;
  line-height: 52rpx;
  text-align: center;
  border: none;
  margin-right: 20rpx;
}

.bar-danger-btn {
  width: 320rpx !important;
  flex: 1;
  height: 80rpx;
  line-height: 54rpx;
  background: linear-gradient(90deg, #ff6568 0%, #ef4444 45%, #dc2626 100%) !important;
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
}

.bar-danger-btn::after {
  border: none;
}

/* 团队选择（加入团队弹窗） */
.team-option {
  padding: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  background: #fff;
  box-shadow:
    0 6rpx 20rpx rgba(31, 41, 55, 0.07),
    inset 0 1rpx 0 rgba(255, 255, 255, 1);
}

.team-option.disabled {
  opacity: 0.5;
  background-color: #f5f5f5;
}

.team-option-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.team-option-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.team-option-count {
  font-size: 28rpx;
  color: #666;
}

.team-full {
  font-size: 24rpx;
  color: #fa5151;
}

/* 创建团队按钮（弹窗内容区主操作） */
.create-team-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  transition: transform 0.2s ease;
  color: #fff;
  border-radius: 22rpx;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow:
    0 8rpx 22rpx rgba(102, 126, 234, 0.32),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.25);
}

.create-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.teams-list {
  margin-top: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.team-option-info {
  margin-top: 8rpx;
}

.team-option-amount {
  font-size: 24rpx;
  color: #999;
}

.empty-teams {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 支付记录列表 */
.payment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.payment-item:last-child {
  border-bottom: none;
}

.payment-item-deletable {
  background: rgba(102, 126, 234, 0.06);
  border-radius: 12rpx;
}

.payment-info {
  display: flex;
  flex-direction: column;
}

.payment-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 8rpx;
}

.payment-remark {
  font-size: 24rpx;
  color: #666;
}

.payment-time {
  font-size: 24rpx;
  color: #999;
}

.empty-payments {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* ========== 费用明细筛选 ========== */
.expense-section {
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.expense-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.expense-header:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.06);
}

.expense-title {
  display: flex;
  flex-direction: column;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.expense-hint {
  font-size: 24rpx;
  color: #999;
}

.expense-arrow {
  font-size: 48rpx;
  color: #ccc;
  font-weight: 300;
}


/* 新增支付：分摊成员选择 */
.split-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.split-count {
  font-size: 24rpx;
  color: #667eea;
}

.split-participant-scroll {
  max-height: 360rpx;
  border-radius: 16rpx;
  background: #f8f9fe;
}

.split-participant-item {
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.9);
  transition: background 0.2s ease;
}

.split-participant-item:last-child {
  border-bottom: none;
}

.split-participant-selected {
  background: #eef1fc;
}

.split-participant-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.split-participant-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.split-participant-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.split-participant-sub {
  font-size: 22rpx;
  color: #999;
}

.split-participant-check {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 2rpx solid #d6d9e6;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  flex-shrink: 0;
}

.split-participant-check-on {
  border-color: #667eea;
  background: #667eea;
}

.expense-modal {
  align-items: flex-end;
}

.expense-modal-content {
  width: 100%;
  max-width: 100%;
  height: 85vh;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  box-shadow:
    0 -16rpx 56rpx rgba(31, 41, 55, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 1);
}

/* 日期选择器 */
.date-picker {
  white-space: nowrap;
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  background: #fafafa;
}

.date-tabs {
  display: inline-flex;
  gap: 20rpx;
  margin: 6rpx;
}

.date-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
  min-width: 160rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.date-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
  transform: scale(1.02);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

.date-tab-day {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.date-tab.active .date-tab-day {
  color: #fff;
}

.date-tab-amount {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
}

.date-tab.active .date-tab-amount {
  color: #fff;
}

.date-tab-perperson {
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
}

.date-tab.active .date-tab-perperson {
  color: rgba(255, 255, 255, 0.75);
}

/* 费用列表 */
.expense-list-body {
  flex: 1;
  overflow-y: auto;
  padding: 0 !important;
}

.expense-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
  transition: background 0.2s ease;
}

.expense-item:active {
  background: #f8f9fe;
}

.expense-item:last-child {
  border-bottom: none;
}

.expense-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.expense-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.expense-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.expense-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.expense-remark {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 380rpx;
}

.expense-time {
  font-size: 22rpx;
  color: #999;
}

.expense-split-label {
  font-size: 22rpx;
  color: #667eea;
  margin-top: 4rpx;
}

.expense-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.empty-expenses {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: #999;
}

.empty-expenses text {
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 提示栏 */
.expense-hint-bar {
  background: #fffbeb;
  padding: 16rpx 30rpx;
  border-bottom: 2rpx solid #fef3c7;
}

.expense-hint-text {
  font-size: 24rpx;
  color: #d97706;
}

/* 删除确认弹窗 */
.btn-danger {
  background: linear-gradient(90deg, #ff6568 0%, #ef4444 45%, #dc2626 100%) !important;
  color: #fff !important;
}

/* 申请按钮 */
.btn-apply {
  background-color: #10b981 !important;
  color: #fff !important;
}

/* ========== 活动笔记 ========== */
.activity-note-section {
  padding: 0 20rpx 20rpx;
  margin-bottom: 16px;
}

.activity-note-section-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
}

.activity-note-section-card--hover {
  opacity: 0.94;
}

.activity-note-section-card--ended {
  box-shadow: 0 2rpx 10rpx rgba(102, 126, 234, 0.05);
}

.activity-note-ended-hint {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 500;
}

.activity-note-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.activity-note-title-block {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.activity-note-hint {
  font-size: 24rpx;
  color: #999;
}

.activity-note-arrow {
  font-size: 48rpx;
  color: #ccc;
  font-weight: 300;
}

.activity-note-preview {
  margin-top: 20rpx;
}

.note-mp-html {
  word-break: break-word;
}

.note-mp-html--preview {
  max-height: 360rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.note-preview-flow {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx 10rpx;
}

.note-preview-inline-rich {
  font-size: 28rpx;
  color: #444;
  line-height: 1.55;
}

.note-preview-inline-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-word;
}

.note-preview-item-text {
  max-width: 100%;
  flex: 1 1 auto;
}

.note-preview-item-img {
  flex-shrink: 0;
  line-height: 0;
}

.note-preview-inline-img {
  display: block;
  max-width: 100%;
  height: auto;
  border-radius: 4rpx;
}

.activity-note-empty {
  font-size: 26rpx;
  color: #999;
}

.activity-note-fs {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 3000;
  background: #f7f8fa;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.activity-note-fs-header {
  flex-shrink: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.activity-note-fs-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.activity-note-fs-side {
  min-width: 96rpx;
  font-size: 30rpx;
  color: #666;
}

.activity-note-fs-action {
  text-align: right;
  color: #667eea;
  font-weight: 500;
}

.activity-note-fs-scroll {
  box-sizing: border-box;
  width: 100%;
  flex-shrink: 0;
}

.activity-note-fs-inner {
  padding: 24rpx 24rpx 48rpx;
  min-height: 100%;
}

.activity-note-fs-inner--edit {
  padding-bottom: 24rpx;
}

.note-edit-toolbar {
  flex-shrink: 0;
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  padding: 24rpx 16rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solidrgb(240, 240, 240);
  box-shadow: 0 -6rpx 24rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.note-edit-toolbar--kb {
  padding-bottom: 14rpx;
}

.note-tool-icon {
  width: 66rpx;
  height: 66rpx;
  border-radius: 16rpx;
  background:rgb(245, 245, 245);
  display: flex;
  align-items: center;
  justify-content: center;
}

.note-tool-icon--on {
  background: #e8ecff;
  box-shadow: inset 0 0 0 2rpx #667eea;
}

.note-tool-img {
  width: 40rpx;
  height: 40rpx;
}

.note-rich-editor--writing {
  padding: 16rpx 18rpx;
  min-height: 360rpx;
}

/* 编辑态：由 note.wxml 绑定 min-height/height，去掉默认小高度限制 */
.note-rich-shell--edit .note-rich-editor--writing {
  min-height: 0;
  box-sizing: border-box;
}

.note-rich-shell--edit .note-editor-main {
  min-height: 0;
  box-sizing: border-box;
}

.note-editor-main {
  display: block;
  width: 100%;
  min-height: 400rpx;
  font-size: 30rpx;
  line-height: 1.65;
  color: #333;
}

/* 与 NOTE_IMG_HTML_STYLE / 阅读态 mp-html 一致，避免 insertImage 宽高与样式不一致导致变形 */
.note-editor-main img {
  display: block;
  max-width: 100%;
  height: auto;
  width: auto;
  vertical-align: top;
  box-sizing: border-box;
}

.note-rich-editor--readonly {
  min-height: 120rpx;
  padding: 16rpx 18rpx;
  box-sizing: border-box;
}

.note-rich-flow--read {
  align-items: center;
}

.note-flow-read-text {
  flex: 1 1 100%;
  max-width: 100%;
  font-size: 30rpx;
  line-height: 1.65;
  color: #333;
}

.note-flow-attach {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 14rpx;
  background: #f4f4f5;
  border-radius: 8rpx;
  max-width: 100%;
}

.note-attach-label {
  font-size: 20rpx;
  color: #667eea;
  flex-shrink: 0;
}

.note-attach-name {
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-preview-attach-chip {
  padding: 4rpx 12rpx;
  background: #f0f2f5;
  border-radius: 8rpx;
}

.note-preview-attach-txt {
  font-size: 24rpx;
  color: #555;
}

.note-full-empty {
  padding: 80rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  line-height: 1.6;
}

.note-rich-shell {
  width: 100%;
}

.note-rich-editor {
  width: 100%;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  min-height: 220rpx;
}

.note-rich-flow {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  align-content: flex-start;
  gap: 8rpx 10rpx;
  width: 100%;
}

.note-flow-text-wrap {
  display: inline-block;
  vertical-align: middle;
  max-width: 100%;
  box-sizing: border-box;
}

.note-flow-text-wrap--focus {
  display: block;
  width: 100%;
  flex: 1 1 100%;
}

.note-textarea--rich {
  width: 100%;
  min-height: 72rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
  background: #fafafa;
  border-radius: 10rpx;
  padding: 10rpx 12rpx;
  box-sizing: border-box;
}

.note-text-tap--rich {
  display: inline-block;
  min-width: 64rpx;
  max-width: 100%;
  padding: 6rpx 12rpx;
  background: #fafafa;
  border-radius: 10rpx;
  vertical-align: middle;
  box-sizing: border-box;
}

.note-text-tap-ph-text {
  font-size: 28rpx;
  color: #b0b0b0;
  line-height: 1.5;
}

.note-text-read--rich {
  font-size: 30rpx;
  color: #333;
  line-height: 1.65;
  white-space: pre-wrap;
  word-break: break-word;
  vertical-align: middle;
}

.note-flow-img-wrap {
  display: inline-block;
  vertical-align: middle;
  flex-shrink: 0;
  line-height: 0;
}

.note-inline-img-wrap {
  position: relative;
  display: inline-block;
  vertical-align: middle;
  line-height: 0;
}

.note-inline-img {
  display: block;
  max-width: 100%;
  height: auto;
  border-radius: 6rpx;
  vertical-align: middle;
}

.note-inline-img-del {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 30rpx;
  height: 30rpx;
  line-height: 28rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.65);
  color: #fff;
  border-radius: 50%;
  font-size: 22rpx;
  z-index: 1;
}

.note-flow-loc-wrap {
  display: inline-block;
  vertical-align: middle;
  flex-shrink: 0;
  max-width: 100%;
}

.note-loc-chip {
  min-height: 48rpx;
  padding: 18rpx 26rpx;
  box-sizing: border-box;
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  max-width: 100%;
  border-radius: 999rpx;
  background: rgba(113, 94, 189, 0.16);
  border: 2rpx solid rgba(113, 94, 189, 0.35);
  box-shadow: 0 6rpx 18rpx rgba(113, 94, 189, 0.12);
}

.note-loc-chip-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: rgb(95, 78, 168);
  font-weight: 600;
  line-height: 1.4;
  white-space: nowrap;
  max-width: 480rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ========== 权重编辑抽屉 ========== */
.weight-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s, visibility 0.25s;
}

.weight-mask-show {
  opacity: 1;
  visibility: visible;
}

.weight-drawer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 2001;
  transform: translateY(100%);
  transition: transform 0.25s ease-out;
  padding-bottom: env(safe-area-inset-bottom);
}

.weight-drawer-show {
  transform: translateY(0);
}

.weight-drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.weight-drawer-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #303133;
}

.weight-drawer-close {
  font-size: 44rpx;
  color: #909399;
  padding: 0 8rpx;
  line-height: 1;
}

.weight-drawer-body {
  padding: 32rpx 32rpx 40rpx;
}

.weight-member-name {
  font-size: 28rpx;
  color: #606266;
  margin-bottom: 12rpx;
}

.weight-desc {
  font-size: 24rpx;
  color: #909399;
  margin: 12rpx 0 24rpx;
  display: block;
}

.weight-presets {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.weight-preset {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f7f8fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #606266;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.weight-preset-active {
  background: #eef1fc;
  border-color: #667eea;
  color: #667eea;
  font-weight: 600;
}

.weight-field {
  display: flex;
  align-items: center;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  margin-bottom: 28rpx;
}

.weight-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #606266;
  flex-shrink: 0;
}

.weight-input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.weight-submit-btn {
  width: 100%;
  height: 80rpx;
  line-height: 52rpx;
  background: #667eea;
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
}

.weight-submit-btn[disabled] {
  background: #b0b8e0;
}
