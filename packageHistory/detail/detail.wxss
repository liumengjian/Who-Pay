/* pages/history/detail.wxss — 与活动详情共用主包样式文件（分包间不可互相 import） */
@import '../../styles/activity-detail-shared.wxss';

page {
  background: #f7f8fa;
}

/* 与 scroll-view 可视高度一致，少内容时也占满一屏 */
.history-detail-page {
  box-sizing: border-box;
}

.end-time {
  margin-top: 20rpx;
  text-align: center;
  font-size: 24rpx;
  opacity: 0.8;
}
.copy-icon {
  width: 36rpx;
  height: 36rpx;
}
