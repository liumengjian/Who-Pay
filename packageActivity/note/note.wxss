/* 与同分包 activity 详情页共用底层样式 */
@import '../detail/detail.wxss';

.page-hero-note {
  min-height: 100vh;
  box-sizing: border-box;
}

.note-edit-bottom-wrap {
  flex-shrink: 0;
  background: #fff;
}

.note-fontsize-panel {
  padding: 12rpx 24rpx 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  background: #fafafa;
}

.note-fontsize-panel-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.note-fontsize-hint {
  font-size: 26rpx;
  color: #5c6bc0;
  font-weight: 600;
  flex-shrink: 0;
  width: 64rpx;
}

.note-fontsize-slider {
  flex: 1;
  min-width: 0;
  margin: 0 8rpx;
}

.note-fontsize-val {
  font-size: 26rpx;
  color: #333;
  font-variant-numeric: tabular-nums;
  flex-shrink: 0;
  width: 88rpx;
  text-align: right;
}

.note-color-panel {
  padding: 16rpx 20rpx 8rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  background: #fafafa;
}

.note-color-panel--v2 .note-color-panel-hint {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.note-hue-strip-hit {
  position: relative;
  height: 48rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.12);
  margin-bottom: 16rpx;
}

.note-hue-strip-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    90deg,
    #f00 0%,
    #ff0 17%,
    #0f0 33%,
    #0ff 50%,
    #00f 67%,
    #f0f 83%,
    #f00 100%
  );
  pointer-events: none;
}

.note-hue-thumb {
  position: absolute;
  top: 4rpx;
  bottom: 4rpx;
  width: 8rpx;
  margin-left: -4rpx;
  background: #fff;
  border-radius: 4rpx;
  box-shadow: 0 0 0 2rpx rgba(0, 0, 0, 0.35);
  pointer-events: none;
}

.note-color-presets {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 8rpx;
}

.note-color-preset-swatch {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(0, 0, 0, 0.12);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.2);
}

.note-color-panel-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-top: 12rpx;
  margin-top: 8rpx;
}

.note-color-reset {
  font-size: 26rpx;
  color: #667eea;
  padding: 8rpx 12rpx;
}

.note-color-preview {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.12);
}
