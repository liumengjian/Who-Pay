/* pages/notification/index.wxss */
.refresh-scroll,
.notification-scroll {
  overflow: hidden;
}

.notification-page {
  box-sizing: border-box;
  background: #f7f8fa;
  padding: 24rpx;
  min-height: 100%;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 200rpx 0;
}

/* 消息卡片 */
.msg-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
  position: relative;
  overflow: hidden;
}

/* 审批卡片：左边带主题色竖条 */
.msg-approve {
  border-left: 6rpx solid #667eea;
}

/* 已处理的审批卡片：灰色竖条 — 具体样式见文末 .msg-item.msg-item-done（需覆盖各类型左边条） */

/* 申请卡片：左边带次要色竖条 */
.msg-apply {
  border-left: 6rpx solid #10b981;
}
.msg-system-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
/* 消息类型标签 */
.msg-type-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 16rpx;
}

.tag-approve {
  background: #eef2ff;
  color: #667eea;
}

.tag-apply {
  background: #f0fdf4;
  color: #10b981;
}

.tag-system {
  background: #fff7ed;
  color: #ea580c;
}

.msg-system {
  border-left: 6rpx solid #ea580c;
}

.msg-system-unread {
  background: #fffdfb;
}

/* 已读系统通知 / 已处理审批 / 已完结申请：变淡变灰（须在本块之后以覆盖 msg-approve、msg-apply、msg-system 的左边条） */
.msg-item.msg-item-done {
  opacity: 0.58;
  border-left: 6rpx solid #d1d5db;
}

.msg-system-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 32rpx;
}

.msg-system-icon {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
  border-radius: 80rpx;
}

.msg-system-main {
  flex: 1;
  min-width: 0;
}

.msg-system-title-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.msg-system-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.msg-system-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ef4444;
  flex-shrink: 0;
}

.msg-system-sub {
  font-size: 24rpx;
  color: #ea580c;
  margin-bottom: 6rpx;
}

.msg-system-time {
  font-size: 22rpx;
  color: #999;
}

.msg-system-go {
  flex-shrink: 0;
  padding-left: 8rpx;
}

.msg-system-arrow {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.5;
}

/* 卡片内容 */
.msg-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.msg-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.msg-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.msg-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.msg-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.msg-time {
  font-size: 22rpx;
  color: #999;
}

/* 操作区 */
.msg-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  gap: 12rpx;
  flex: 0 0 25%;
  min-width: 0;
}

.msg-actions button {
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  border: none;
  padding: 0;
  width: 100%
}

.btn-approve {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.btn-reject {
  background: #fff;
  color: #999;
  border: 2rpx solid #e5e5e5 !important;
}

.btn-cancel {
  background: #fff;
  color: #ef4444;
  border: 2rpx solid #fecaca !important;
}

/* 状态标签 */
.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  text-align: center;
  min-width: 100rpx;
}

.tag-pending {
  background: #fffbeb;
  color: #d97706;
}

.tag-approved {
  background: #f0fdf4;
  color: #10b981;
}

.tag-rejected {
  background: #fef2f2;
  color: #ef4444;
}

/* 空状态 */
.empty-wrapper {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}

.empty-wrapper .empty-state {
  align-items: center;
  justify-content: center;
}

.empty-wrapper .empty-icon {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.4;
}

.empty-wrapper .empty-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
}
