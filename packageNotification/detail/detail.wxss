.bar-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
}

.detail-scroll {
  box-sizing: border-box;
  background: #f7f8fa;
}

.detail-loading {
  padding: 120rpx;
  text-align: center;
}

.text-muted {
  color: #999;
  font-size: 28rpx;
}

.detail-body {
  padding: 32rpx;
}

.detail-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.4;
  margin-bottom: 24rpx;
}

.detail-content {
  display: block;
  font-size: 30rpx;
  color: #374151;
  line-height: 1.65;
  white-space: pre-wrap;
  word-break: break-word;
}
