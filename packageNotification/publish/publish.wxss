.publish-page {
  min-height: 100vh;
  box-sizing: border-box;
  background: #f7f8fa;
  padding: 24rpx;
}

.bar-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
}

/* Tab 切换栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}

.tab-item.tab-active {
  color: #667eea;
  border-bottom-color: #667eea;
  font-weight: 600;
}

.form-card {
  background: #fff;
  border-radius: 0 0 20rpx 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.field-label.margin-top {
  margin-top: 28rpx;
}

.field-input {
  height: 80rpx;
  padding: 0 20rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.field-textarea {
  min-height: 240rpx;
  padding: 20rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.guide-textarea {
  min-height: 500rpx;
}

.publish-btn {
  margin-top: 40rpx;
  height: 76rpx;
  line-height: 52rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.publish-btn::after {
  border: none;
}

.publish-hint {
  display: block;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

/* 新手指引编辑 */
.guide-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.add-section-btn {
  font-size: 24rpx;
  color: #667eea;
  background: none;
  border: none;
  padding: 8rpx 16rpx;
  line-height: 1;
}

.add-section-btn::after {
  border: none;
}

.field-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 24rpx;
  line-height: 1.4;
}

.loading-hint {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}

.guide-section-card {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.guide-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.guide-section-index {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 600;
}

.guide-section-remove {
  font-size: 24rpx;
  color: #e74c3c;
  padding: 6rpx 12rpx;
}

.input-group {
  margin-bottom: 16rpx;
}

.input-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.required {
  color: #e74c3c;
}
