.publish-page {
  min-height: 100vh;
  box-sizing: border-box;
  background: #f7f8fa;
  padding: 24rpx;
}

.bar-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.field-label.margin-top {
  margin-top: 28rpx;
}

.field-input {
  height: 80rpx;
  padding: 0 20rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.field-textarea {
  min-height: 240rpx;
  padding: 20rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.publish-btn {
  margin-top: 40rpx;
  height: 76rpx;
  line-height: 52rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.publish-btn::after {
  border: none;
}

.publish-hint {
  display: block;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}
