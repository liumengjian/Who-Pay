<cu-custom bgColor="bg-gradual-blue" isBack="{{true}}">
</cu-custom>
<view class="publish-page">
  <!-- Tab 切换栏 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 'notice' ? 'tab-active' : ''}}" data-tab="notice" bindtap="switchTab">更新公告</view>
    <view class="tab-item {{currentTab === 'guide' ? 'tab-active' : ''}}" data-tab="guide" bindtap="switchTab">新手指引</view>
  </view>

  <!-- 更新公告 Tab -->
  <view wx:if="{{currentTab === 'notice'}}" class="form-card">
    <text class="field-label">通知标题</text>
    <input
      class="field-input"
      placeholder="请输入标题"
      value="{{title}}"
      maxlength="500"
      bindinput="onTitleInput"
    />
    <text class="field-label margin-top">通知正文</text>
    <textarea
      class="field-textarea"
      placeholder="请输入正文内容"
      value="{{body}}"
      maxlength="8000"
      auto-height
      bindinput="onBodyInput"
    />
    <button class="publish-btn" bindtap="onPublish">发布</button>
    <text class="publish-hint">将向所有注册用户推送一条「版本更新」类系统通知</text>
  </view>

  <!-- 新手指引 Tab -->
  <view wx:if="{{currentTab === 'guide'}}" class="form-card">
    <text class="field-label">新手指引内容</text>
    <text class="field-hint">新用户注册时将自动收到此指引内容。支持多行文本，章节之间请用空行分隔。</text>

    <view wx:if="{{guideLoading}}" class="loading-hint">加载中...</view>

    <textarea
      wx:if="{{!guideLoading}}"
      class="field-textarea guide-textarea"
      placeholder="请输入新手指引内容"
      value="{{guideBody}}"
      maxlength="10000"
      auto-height
      bindinput="onGuideBodyInput"
    />

    <button class="publish-btn" bindtap="onSaveGuide">保存</button>
  </view>
</view>
